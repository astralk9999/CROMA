---
import PublicLayout from '@layouts/PublicLayout.astro';
import { ui, defaultLang, useTranslations } from '@lib/i18n';

const lang = Astro.locals.lang || defaultLang;
const t = useTranslations(lang as keyof typeof ui);

// We rely on the session being set by the callback before reaching this page
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect('/auth/login?error=Sesión expirada o inválida. Por favor, solicita otro enlace de recuperación.');
}

// Check if user logged in via OAuth only (no email/password provider)
const identities = user.identities || [];
const hasPasswordIdentity = identities.some((id: any) => id.provider === 'email');
const oauthProvider = identities.find((id: any) => id.provider !== 'email')?.provider;
const isOAuthOnly = !hasPasswordIdentity && identities.length > 0;
---

<PublicLayout title={t('auth.update.title')}>
  <section class="min-h-screen bg-gray-50 py-12">
    <div class="container-custom">
      <div class="max-w-md mx-auto">
        <div class="text-center mb-8">
          <h1 class="text-4xl font-bold text-gray-900 mb-2">{t('auth.update.header')}</h1>
          <p class="text-gray-600">{t('auth.update.subtitle')}</p>
        </div>

        <div class="bg-white rounded-2xl shadow-xl p-8">
          <!-- Client-side Message Container -->
          <div id="status-message" class="hidden mb-6 p-4 rounded border-l-4">
            <div class="flex items-center">
              <div id="status-icon" class="mr-2"></div>
              <p id="status-text" class="text-sm font-medium"></p>
            </div>
          </div>

          {isOAuthOnly ? (
            <!-- OAuth-only user: can't change password -->
            <div class="text-center space-y-4">
              <div class="mx-auto w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center">
                <svg class="w-8 h-8 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-gray-900">
                Cuenta vinculada con {oauthProvider === 'google' ? 'Google' : oauthProvider || 'proveedor externo'}
              </h3>
              <p class="text-gray-600 text-sm leading-relaxed">
                Tu cuenta fue creada con {oauthProvider === 'google' ? 'Google' : oauthProvider || 'un proveedor externo'}, por lo que no tiene contraseña asociada. 
                Para iniciar sesión simplemente usa el botón de {oauthProvider === 'google' ? 'Google' : oauthProvider || 'tu proveedor'}.
              </p>
              <div class="pt-4 space-y-3">
                <a href="/account/profile" class="block w-full bg-black text-white py-3 rounded-lg hover:bg-gray-800 transition-all font-semibold text-center">
                  Volver al Perfil
                </a>
              </div>
            </div>
          ) : (
            <!-- Normal user: show password change form -->
            <form id="update-password-form" class="space-y-5">
              <div>
                <label for="password" class="block text-sm font-semibold text-gray-700 mb-2">
                  {t('auth.login.placeholder.password')}
                </label>
                <input
                  type="password"
                  id="password"
                  name="password"
                  required
                  minlength="6"
                  class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-black transition-all"
                  placeholder="Mínimo 6 caracteres"
                />
              </div>

              <div>
                <label for="confirm_password" class="block text-sm font-semibold text-gray-700 mb-2">
                  {t('auth.register.placeholder.confirm')}
                </label>
                <input
                  type="password"
                  id="confirm_password"
                  name="confirm_password"
                  required
                  class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-black focus:border-black transition-all"
                  placeholder={t('auth.register.placeholder.confirm')}
                />
              </div>

              <button
                type="submit"
                id="submit-btn"
                class="w-full bg-black text-white py-3.5 rounded-lg hover:bg-gray-800 transition-all font-semibold text-lg shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
              >
                {t('auth.update.button')}
              </button>
            </form>
          )}
        </div>
      </div>
    </div>
  </section>

  <script>
    import { supabase } from '@lib/supabase';

    const form = document.getElementById('update-password-form') as HTMLFormElement | null;
    if (!form) {
      // OAuth-only user — no form to handle
    } else {
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      const statusContainer = document.getElementById('status-message') as HTMLDivElement;
      const statusIcon = document.getElementById('status-icon') as HTMLDivElement;
      const statusText = document.getElementById('status-text') as HTMLParagraphElement;

      function showStatus(msg: string, isError: boolean) {
        statusContainer.classList.remove('hidden', 'bg-red-50', 'border-red-500', 'text-red-700', 'bg-green-50', 'border-green-500', 'text-green-700');
        
        if (isError) {
          statusContainer.classList.add('bg-red-50', 'border-red-500', 'text-red-700');
          statusIcon.innerHTML = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>`;
        } else {
          statusContainer.classList.add('bg-green-50', 'border-green-500', 'text-green-700');
          statusIcon.innerHTML = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>`;
        }
        
        statusText.textContent = msg;
        statusContainer.classList.remove('hidden');
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const formData = new FormData(form);
        const password = formData.get('password') as string;
        const confirmPassword = formData.get('confirm_password') as string;

        if (password !== confirmPassword) {
          showStatus('Las contraseñas no coinciden', true);
          return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Actualizando...';
        statusContainer.classList.add('hidden');

        try {
          const { error } = await supabase.auth.updateUser({
            password: password
          });

          if (error) throw error;

          showStatus('Contraseña actualizada correctamente', false);
          setTimeout(() => {
            window.location.href = '/account/profile?message=Contraseña actualizada';
          }, 2000);
          
        } catch (error: any) {
          console.error('Update password error:', error);
          showStatus(error.message || 'Error al actualizar la contraseña', true);
          submitBtn.disabled = false;
          submitBtn.textContent = 'Actualizar Contraseña';
        }
      });
    }
  </script>
</PublicLayout>
