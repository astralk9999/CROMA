---
export const prerender = false;
import PublicLayout from '@layouts/PublicLayout.astro';
import { ui, defaultLang, useTranslations } from '@lib/i18n';

const lang = Astro.locals.lang || defaultLang;
const t = useTranslations(lang as keyof typeof ui);
---

<PublicLayout title={t('returns.title')}>
  <div class="container-custom py-24 min-h-[60vh]">
    <div class="max-w-5xl mx-auto">
        {/* Header Section */}
        <header class="mb-20">
            <div class="flex items-center gap-4 mb-6">
                <span class="px-3 py-1 bg-[#202020] text-white text-[10px] font-mono font-black uppercase tracking-[0.3em]">{t('returns.header.tag')}</span>
                <div class="h-[2px] flex-1 bg-black/10"></div>
            </div>
            <h1 class="text-6xl md:text-8xl font-urban font-black uppercase tracking-tighter text-black leading-[0.85] mb-6" set:html={t('returns.header.title').replace(' ', '<br/>')}>
            </h1>
            <p class="text-zinc-500 font-mono text-sm uppercase tracking-widest max-w-xl">
                {t('returns.header.subtitle')}
            </p>
        </header>

        {/* Step by Step Flow */}
        <section class="mb-24">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-2 border-black divide-y-2 md:divide-y-0 md:divide-x-2 divide-black overflow-hidden rounded-[2rem]">
                <div class="p-10 bg-white group hover:bg-zinc-50 transition-colors">
                    <div class="text-4xl font-black text-zinc-200 mb-6 group-hover:text-black transition-colors">01</div>
                    <h3 class="text-xl font-black uppercase mb-4 tracking-tighter">{t('returns.step1.title')}</h3>
                    <p class="text-sm text-zinc-500 font-bold uppercase tracking-wider leading-relaxed">
                        {t('returns.step1.desc').split('{link}')[0]}
                        <a href="/account/profile" class="text-black underline underline-offset-4 decoration-2">{t('returns.step1.profile')}</a>
                        {t('returns.step1.desc').split('{link}')[1]}
                    </p>
                </div>
                <div class="p-10 bg-white group hover:bg-zinc-50 transition-colors">
                    <div class="text-4xl font-black text-zinc-200 mb-6 group-hover:text-black transition-colors">02</div>
                    <h3 class="text-xl font-black uppercase mb-4 tracking-tighter">{t('returns.step2.title')}</h3>
                    <p class="text-sm text-zinc-500 font-bold uppercase tracking-wider leading-relaxed">
                        {t('returns.step2.desc')}
                    </p>
                </div>
                <div class="p-10 bg-white group hover:bg-zinc-50 transition-colors">
                    <div class="text-4xl font-black text-zinc-200 mb-6 group-hover:text-black transition-colors">03</div>
                    <h3 class="text-xl font-black uppercase mb-4 tracking-tighter">{t('returns.step3.title')}</h3>
                    <p class="text-sm text-zinc-500 font-bold uppercase tracking-wider leading-relaxed">
                        {t('returns.step3.desc')}
                    </p>
                </div>
            </div>
        </section>

        <div class="grid lg:grid-cols-3 gap-16">
            <div class="lg:col-span-2 space-y-20">
                {/* Detailed Polices */}
                <section>
                    <div class="flex items-center gap-3 mb-10 border-b-4 border-black pb-4">
                        <span class="w-3 h-3 bg-black rounded-full"></span>
                        <h2 class="text-3xl font-black uppercase tracking-tighter">{t('returns.policy.title')}</h2>
                    </div>

                    <div class="space-y-12">
                        <div>
                            <h4 class="text-[12px] font-black uppercase tracking-[0.2em] mb-4 text-zinc-400">{t('returns.policy.item1.title')}</h4>
                            <p class="text-xl font-urban font-bold leading-snug">{t('returns.policy.item1.desc')}</p>
                        </div>
                        <div>
                            <h4 class="text-[12px] font-black uppercase tracking-[0.2em] mb-4 text-zinc-400">{t('returns.policy.item2.title')}</h4>
                            <p class="text-xl font-urban font-bold leading-snug tracking-tight italic">
                                {t('returns.policy.item2.desc')}
                            </p>
                        </div>
                        <div class="p-8 bg-zinc-50 border-l-4 border-[#202020] rounded-r-2xl">
                            <h4 class="text-[12px] font-black uppercase tracking-[0.2em] mb-4 text-[#202020]">{t('returns.policy.item3.title')}</h4>
                            <p class="text-sm text-zinc-600 font-bold leading-relaxed uppercase tracking-wider">
                                {t('returns.policy.item3.desc')}
                            </p>
                        </div>
                    </div>
                </section>

                {/* Exchanges section */}
                <section>
                    <div class="flex items-center gap-3 mb-10 border-b-4 border-black pb-4">
                        <span class="w-3 h-3 bg-black rounded-full"></span>
                        <h2 class="text-3xl font-black uppercase tracking-tighter">{t('returns.exchanges.title')}</h2>
                    </div>
                    <p class="text-lg font-bold text-zinc-500 uppercase tracking-widest leading-loose">
                        {t('returns.exchanges.desc').split('{link}')[0]}
                        <span class="text-black">{t('returns.exchanges.link_text')}</span>
                        {t('returns.exchanges.desc').split('{link}')[1]}
                    </p>
                </section>
            </div>

            {/* Sidebar info */}
            <div class="space-y-8">
                <div class="p-8 bg-black text-white rounded-[2rem] relative overflow-hidden group">
                    <div class="absolute inset-0 bg-gradient-to-br from-zinc-800 to-transparent opacity-50"></div>
                    <h3 class="text-xl font-black uppercase mb-6 relative z-10 italic">{t('returns.sidebar.packaging.title')}</h3>
                    <ul class="space-y-4 relative z-10">
                        <li class="flex items-start gap-3">
                            <svg class="w-5 h-5 text-brand-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                            <span class="text-[11px] font-bold uppercase tracking-wider text-zinc-400">{t('returns.sidebar.packaging.i1')}</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <svg class="w-5 h-5 text-brand-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                            <span class="text-[11px] font-bold uppercase tracking-wider text-zinc-400">{t('returns.sidebar.packaging.i2')}</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <svg class="w-5 h-5 text-brand-red flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                            <span class="text-[11px] font-bold uppercase tracking-wider text-zinc-400">{t('returns.sidebar.packaging.i3')}</span>
                        </li>
                    </ul>
                </div>

                <div class="border-4 border-black p-8 rounded-[2rem] bg-white">
                    <h4 class="font-black uppercase text-xl mb-4 italic">{t('returns.sidebar.help.title')}</h4>
                    <p class="text-xs text-zinc-500 font-black uppercase tracking-widest mb-6">{t('returns.sidebar.help.desc')}</p>
                    <a href="/customer-service" class="group flex items-center justify-between py-4 border-t-2 border-black font-black uppercase tracking-widest text-[10px]">
                        {t('returns.sidebar.help.cta')}
                        <svg class="w-4 h-4 transition-transform group-hover:translate-x-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
  </div>
</PublicLayout>
