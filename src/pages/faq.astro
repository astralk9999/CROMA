---
import PublicLayout from '@layouts/PublicLayout.astro';
import { ui, defaultLang, useTranslations } from '@lib/i18n';

const lang = Astro.locals.lang || defaultLang;
const t = useTranslations(lang as keyof typeof ui);
---

<PublicLayout title={t('faq.title')}>
  <div class="container-custom py-24 min-h-[60vh]">
    <div class="max-w-5xl mx-auto">
        {/* Header Section */}
        <header class="mb-32">
            <div class="flex items-center gap-4 mb-8">
                <span class="px-3 py-1 bg-[#202020] text-white text-[10px] font-mono font-black uppercase tracking-[0.3em]">{t('faq.header.tag')}</span>
                <div class="h-[2px] flex-1 bg-black/10"></div>
            </div>
            <h1 class="text-7xl md:text-[10rem] font-urban font-black uppercase tracking-tighter text-black leading-[0.75] mb-12">
                {t('faq.header.title')}
            </h1>
            <p class="text-xl font-urban font-bold uppercase tracking-tight leading-tight text-zinc-500 max-w-2xl">
                {t('faq.header.subtitle')}
            </p>
        </header>

        {/* Categories Navigation */}
        <div class="flex flex-wrap gap-4 mb-20">
            {(t('faq.categories') as string[]).map((cat) => (
                <span class="px-6 py-2 border-2 border-black font-black uppercase tracking-widest text-xs hover:bg-black hover:text-white transition-all cursor-pointer">
                    {cat}
                </span>
            ))}
        </div>

        {/* FAQ Grid */}
        <div class="grid md:grid-cols-2 gap-1 border-2 border-black bg-black">
            <div class="p-12 bg-white group hover:bg-zinc-50 transition-colors">
                <span class="text-[10px] font-mono font-black text-zinc-300 mb-6 block">{t('faq.q1.tag')}</span>
                <h3 class="text-2xl font-black uppercase tracking-tighter mb-4 italic">{t('faq.q1.title')}</h3>
                <p class="text-sm text-zinc-500 font-bold uppercase tracking-wider leading-relaxed">
                    {t('faq.q1.desc').split('{link}')[0]}
                    <a href="/account/profile" class="text-black underline underline-offset-4">{t('faq.q1.link_text')}</a>
                    {t('faq.q1.desc').split('{link}')[1]}
                </p>
            </div>
            <div class="p-12 bg-white group hover:bg-zinc-50 transition-colors">
                <span class="text-[10px] font-mono font-black text-zinc-300 mb-6 block">{t('faq.q2.tag')}</span>
                <h3 class="text-2xl font-black uppercase tracking-tighter mb-4 italic">{t('faq.q2.title')}</h3>
                <p class="text-sm text-zinc-500 font-bold uppercase tracking-wider leading-relaxed">
                    {t('faq.q2.desc')}
                </p>
            </div>
            <div class="p-12 bg-white group hover:bg-zinc-50 transition-colors">
                <span class="text-[10px] font-mono font-black text-zinc-300 mb-6 block">{t('faq.q3.tag')}</span>
                <h3 class="text-2xl font-black uppercase tracking-tighter mb-4 italic">{t('faq.q3.title')}</h3>
                <p class="text-sm text-zinc-500 font-bold uppercase tracking-wider leading-relaxed">
                    {t('faq.q3.desc')}
                </p>
            </div>
            <div class="p-12 bg-white group hover:bg-zinc-50 transition-colors">
                <span class="text-[10px] font-mono font-black text-zinc-300 mb-6 block">{t('faq.q4.tag')}</span>
                <h3 class="text-2xl font-black uppercase tracking-tighter mb-4 italic">{t('faq.q4.title')}</h3>
                <p class="text-sm text-zinc-500 font-bold uppercase tracking-wider leading-relaxed">
                    {t('faq.q4.desc')}
                </p>
            </div>
            <div class="p-12 bg-white group hover:bg-zinc-50 transition-colors">
                <span class="text-[10px] font-mono font-black text-zinc-300 mb-6 block">{t('faq.q5.tag')}</span>
                <h3 class="text-2xl font-black uppercase tracking-tighter mb-4 italic">{t('faq.q5.title')}</h3>
                <p class="text-sm text-zinc-500 font-bold uppercase tracking-wider leading-relaxed">
                    {t('faq.q5.desc').split('{link}')[0]}
                    <a href="/size-guide" class="text-black underline underline-offset-4">{t('faq.q5.link_text')}</a>
                    {t('faq.q5.desc').split('{link}')[1]}
                </p>
            </div>
            <div class="p-12 bg-white group hover:bg-zinc-50 transition-colors">
                <span class="text-[10px] font-mono font-black text-zinc-300 mb-6 block">{t('faq.q6.tag')}</span>
                <h3 class="text-2xl font-black uppercase tracking-tighter mb-4 italic">{t('faq.q6.title')}</h3>
                <p class="text-sm text-zinc-500 font-bold uppercase tracking-wider leading-relaxed">
                    {t('faq.q6.desc')}
                </p>
            </div>
        </div>

        {/* Help Section */}
        <section class="mt-32 p-12 bg-zinc-50 border-4 border-black rounded-[3rem] text-center">
            <h4 class="text-3xl font-black uppercase mb-4 italic">{t('faq.cta.title')}</h4>
            <p class="text-xs font-black uppercase tracking-[0.3em] text-zinc-400 mb-8">{t('faq.cta.subtitle')}</p>
            <a href="/contact" class="inline-block px-12 py-5 bg-black text-white font-black uppercase tracking-widest text-sm hover:bg-brand-red transition-colors">{t('faq.cta.button')}</a>
        </section>
    </div>
  </div>
</PublicLayout>
