---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import ConfirmationModal from '@components/islands/ConfirmationModal';
import { supabaseAdmin } from '@lib/supabase-admin';

// Server-side Filtering
const url = Astro.url;
const statusFilter = url.searchParams.get('status') || '';
const searchQuery = (url.searchParams.get('search') || url.searchParams.get('q'))?.toLowerCase() || '';
const sortOrder = url.searchParams.get('sort') || 'newest';
const startDate = url.searchParams.get('startDate') || '';
const endDate = url.searchParams.get('endDate') || '';

// 1. Fetch Total Absolute Count for Diagnostic
const { count: rawReturnsCount } = await supabaseAdmin
    .from('return_requests')
    .select('*', { count: 'exact', head: true });

// 2. Build Base Query
let query = supabaseAdmin
  .from('return_requests')
  .select(`
    *,
    profiles (full_name, email),
    orders (total_amount, created_at),
    return_request_items (
        quantity,
        order_items (
            product_name,
            size,
            product_image
        )
    )
  `);

// 3. Apply Server-side Filters
if (statusFilter && statusFilter !== 'all') {
    query = query.eq('status', statusFilter);
}

if (startDate) {
    query = query.gte('created_at', `${startDate}T00:00:00`);
}

if (endDate) {
    query = query.lte('created_at', `${endDate}T23:59:59`);
}

// 4. Apply Sorting
if (sortOrder === 'oldest') {
    query = query.order('created_at', { ascending: true });
} else {
    query = query.order('created_at', { ascending: false });
}

// 5. Execute Query
const { data: allReturns, error: fetchError } = await query;

let filteredReturns = allReturns || [];

// 6. Apply Client-side Search
if (searchQuery) {
    filteredReturns = filteredReturns.filter(r => 
        r.id.toLowerCase().includes(searchQuery) ||
        r.order_id.toLowerCase().includes(searchQuery) ||
        r.reason.toLowerCase().includes(searchQuery) ||
        r.profiles?.email?.toLowerCase().includes(searchQuery) ||
        r.profiles?.full_name?.toLowerCase().includes(searchQuery)
    );
}

const statusLabels: Record<string, string> = {
  pending: 'Pendiente',
  approved: 'Aprobado',
  rejected: 'Rechazado',
  completed: 'Completado'
};

const returnReasons: Record<string, string> = {
    'wrong_size': 'Talla incorrecta',
    'damaged': 'Producto dañado',
    'not_like': 'No me gusta',
    'wrong_item': 'Producto equivocado',
    'other': 'Otro'
};

const activeFiltersCount = [
    statusFilter && statusFilter !== 'all',
    searchQuery,
    startDate,
    endDate
].filter(Boolean).length;
---

<AdminLayout title="Gestión de Devoluciones" activeSection="returns">
  <!-- Status Control Bar (Sticky) -->
  <div class="mb-12 sticky top-0 z-[100] px-0 pt-4 pb-12 bg-zinc-50/80 backdrop-blur-xl transition-all duration-300">
    <div class="bg-zinc-800 rounded-2xl p-1 shadow-[0_20px_50px_rgba(0,0,0,0.5)] relative border border-white/5">
        <div class="absolute -top-10 left-0 text-[8px] font-black text-zinc-400 uppercase tracking-widest bg-zinc-50 px-3 py-1 rounded-t-lg border border-b-0 border-zinc-200">
          Diagnóstico: {rawReturnsCount} Solicitudes | Filtro: {filteredReturns.length}
        </div>
        
        <!-- Accent Glow -->
        <div class="absolute inset-0 rounded-2xl overflow-hidden pointer-events-none">
            <div class="absolute -top-24 -right-24 w-96 h-96 bg-white/5 blur-[120px] rounded-full"></div>
        </div>
        
        <div class="relative z-10 flex flex-col xl:flex-row flex-wrap gap-4 items-center p-2 px-4 lg:px-6">
            <!-- Search Group -->
            <div class="relative flex-1 group/search w-full">
                <!-- Audit Status Gauge -->
                <div class="absolute -top-3 left-8 px-3 py-1 bg-zinc-800 border border-white/10 rounded-sm z-20 opacity-0 group-focus-within/search:opacity-100 transition-all duration-500 translate-y-2 group-focus-within/search:translate-y-0 flex items-center gap-3 shadow-[0_10px_30px_rgba(0,0,0,0.8)]">
                    <div class="flex gap-0.5">
                        <div class="w-1 h-1 bg-white rounded-full animate-pulse"></div>
                        <div class="w-1 h-1 bg-white/40 rounded-full animate-pulse [animation-delay:200ms]"></div>
                        <div class="w-1 h-1 bg-white/10 rounded-full animate-pulse [animation-delay:400ms]"></div>
                    </div>
                    <span class="text-[7px] font-black text-white/90 uppercase tracking-[0.4em]">Auditoría Activa</span>
                </div>

                <form method="GET" id="filter-form" class="relative">
                    <input type="hidden" name="status" value={statusFilter || ''} />
                    <input type="hidden" name="sort" value={sortOrder} />
                    <input type="hidden" name="startDate" value={startDate} />
                    <input type="hidden" name="endDate" value={endDate} />
                    
                    <input
                        type="text"
                        name="search"
                        id="main-search"
                        placeholder="BUSCAR POR ID, EMAIL, NOMBRE..."
                        value={searchQuery || ''}
                        class="w-full bg-white/5 border-2 border-white/10 rounded-xl px-14 py-6 text-white text-[10px] font-black uppercase tracking-[0.2em] focus:outline-none focus:border-white focus:bg-zinc-700/50 focus:ring-8 focus:ring-white/[0.03] focus:shadow-[0_0_50px_rgba(255,255,255,0.08)] focus:tracking-[0.3em] transition-all duration-500 placeholder:text-white/10 placeholder:font-bold selection:bg-white selection:text-black"
                    />
                    <svg class="absolute left-6 top-1/2 -translate-y-1/2 w-5 h-5 text-white/20 group-focus-within/search:text-white group-focus-within/search:scale-110 group-hover:text-white/40 transition-all duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </form>
            </div>

            <!-- Date Filter -->
            <div class="relative group/dropdown">
                <button type="button" id="ret-date-btn" class={`h-14 px-6 rounded-xl flex items-center justify-between gap-3 text-[9px] font-black uppercase tracking-widest transition-all border-2 bg-white/0 hover:bg-white/5 border-white/10 !text-white hover:border-white/30 ${startDate || endDate ? 'bg-white !text-black border-white' : ''}`}>
                    <svg class="w-3.5 h-3.5 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    {startDate ? `DESDE: ${startDate}` : endDate ? `HASTA: ${endDate}` : 'FECHA'}
                    <svg class="w-3 h-3 opacity-20 transition-transform arrow" id="ret-date-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div id="ret-date-menu" class="absolute top-full right-0 w-64 mt-2 bg-zinc-800 border border-white/10 rounded-2xl overflow-hidden hidden z-[200] shadow-2xl">
                    <div class="p-4 space-y-4">
                        <div class="space-y-1">
                            <a href={`?status=${statusFilter || 'all'}&search=${searchQuery || ''}&sort=${sortOrder}`} class="block px-4 py-2 rounded-lg text-[8px] font-black uppercase tracking-widest text-zinc-400 hover:bg-white/5 hover:text-white transition-all">CUALQUIER FECHA</a>
                            <a href={`?status=${statusFilter || 'all'}&search=${searchQuery || ''}&sort=${sortOrder}&startDate=${new Date().toISOString().split('T')[0]}`} class="block px-4 py-2 rounded-lg text-[8px] font-black uppercase tracking-widest text-zinc-400 hover:bg-white/5 hover:text-white transition-all">HOY</a>
                        </div>
                        <div class="h-px bg-white/5"></div>
                        <form method="get" class="space-y-3">
                            <input type="hidden" name="status" value={statusFilter || 'all'} />
                            <input type="hidden" name="q" value={searchQuery || ''} />
                            <input type="hidden" name="sort" value={sortOrder} />
                            <div class="grid grid-cols-1 gap-2">
                                <div class="relative">
                                    <span class="absolute -top-2 left-2 px-1 bg-zinc-800 text-[6px] font-black text-white/40 uppercase tracking-widest">Desde</span>
                                    <input type="date" name="startDate" value={startDate} class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-[9px] font-black uppercase [color-scheme:dark]" />
                                </div>
                                <div class="relative">
                                    <span class="absolute -top-2 left-2 px-1 bg-zinc-800 text-[6px] font-black text-white/40 uppercase tracking-widest">Hasta</span>
                                    <input type="date" name="endDate" value={endDate} class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-[9px] font-black uppercase [color-scheme:dark]" />
                                </div>
                            </div>
                            <button type="submit" class="w-full py-3 bg-white text-black text-[8px] font-black uppercase tracking-widest rounded-lg hover:bg-zinc-100 transition-all">APLICAR RANGO</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Vertical Divider -->
            <div class="hidden lg:block w-px h-10 bg-white/10"></div>

            <!-- Dropdowns Group -->
            <div class="grid grid-cols-2 gap-1 w-full lg:w-auto">
                <!-- Status Filter -->
                <div class="relative group/dropdown">
                    <button type="button" id="ret-status-btn" 
                        class={`w-full h-14 px-6 rounded-xl flex items-center justify-between gap-3 text-[9px] font-black uppercase tracking-widest transition-all border-2 
                            ${statusFilter && statusFilter !== 'all'
                                ? 'bg-white text-black border-white shadow-[0_0_20px_rgba(255,255,255,0.2)]' 
                                : 'bg-white/0 hover:bg-white/5 border-white/10 !text-white hover:border-white/30'}`}>
                        <span class="flex items-center gap-2 truncate">
                            <svg class={`w-3.5 h-3.5 ${statusFilter && statusFilter !== 'all' ? 'text-black/40' : 'text-white/40'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            {statusFilter && statusFilter !== 'all' ? (statusLabels[statusFilter]?.toUpperCase() || 'ESTADO') : 'ESTADO'}
                        </span>
                        <svg class={`w-3 h-3 transition-transform ${statusFilter && statusFilter !== 'all' ? 'text-black/40' : 'text-white/20'}`} id="ret-status-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div id="ret-status-menu" class="absolute top-full left-0 right-0 lg:w-64 mt-2 bg-zinc-800 border border-white/10 rounded-2xl overflow-hidden hidden z-[200] shadow-2xl backdrop-blur-xl">
                        <div class="p-2 space-y-1">
                            <a href={`?q=${searchQuery || ''}&sort=${sortOrder}&startDate=${startDate}&endDate=${endDate}&status=all`} class="block px-4 py-3 rounded-xl text-[8px] font-black uppercase tracking-widest text-zinc-400 hover:bg-white/5 hover:text-white transition-all">TODOS</a>
                            <a href={`?q=${searchQuery || ''}&sort=${sortOrder}&startDate=${startDate}&endDate=${endDate}&status=pending`} class="block px-4 py-3 rounded-xl text-[8px] font-black uppercase tracking-widest text-zinc-400 hover:bg-white/5 hover:text-white transition-all">PENDIENTES</a>
                            <a href={`?q=${searchQuery || ''}&sort=${sortOrder}&startDate=${startDate}&endDate=${endDate}&status=approved`} class="block px-4 py-3 rounded-xl text-[8px] font-black uppercase tracking-widest text-zinc-400 hover:bg-white/5 hover:text-white transition-all">APROBADOS</a>
                            <a href={`?q=${searchQuery || ''}&sort=${sortOrder}&startDate=${startDate}&endDate=${endDate}&status=rejected`} class="block px-4 py-3 rounded-xl text-[8px] font-black uppercase tracking-widest text-zinc-400 hover:bg-white/5 hover:text-white transition-all">RECHAZADOS</a>
                        </div>
                    </div>
                </div>

                <!-- Sort Filter -->
                <div class="relative group/dropdown">
                    <button type="button" id="ret-sort-btn" 
                        class={`w-full h-14 px-6 rounded-2xl flex items-center justify-between gap-3 text-[9px] font-black uppercase tracking-widest transition-all border-2 
                            ${sortOrder && sortOrder !== 'newest'
                                ? 'bg-white text-black border-white shadow-[0_0_20px_rgba(255,255,255,0.2)]' 
                                : 'bg-white/0 hover:bg-white/5 border-white/10 !text-white hover:border-white/30'}`}>
                        <span class="flex items-center gap-2 truncate">
                            <svg class={`w-3.5 h-3.5 ${sortOrder && sortOrder !== 'newest' ? 'text-black/40' : 'text-white/40'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"/></svg>
                            {sortOrder === 'newest' ? 'FECHA ↓' : 'FECHA ↑'}
                        </span>
                        <svg class={`w-3 h-3 transition-transform ${sortOrder && sortOrder !== 'newest' ? 'text-black/40' : 'text-white/20'}`} id="ret-sort-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div id="ret-sort-menu" class="absolute top-full right-0 lg:w-64 mt-2 bg-zinc-800 border border-white/10 rounded-3xl overflow-hidden hidden z-[200] shadow-2xl backdrop-blur-xl">
                        <div class="p-2 space-y-1">
                            <a href={`?status=${statusFilter || 'all'}&search=${searchQuery || ''}&startDate=${startDate}&endDate=${endDate}&sort=newest`} class={`block px-5 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all ${sortOrder === 'newest' ? 'bg-white text-black' : 'text-zinc-400 hover:bg-white/5 hover:text-white'}`}>
                                <span class="flex items-center justify-between gap-4">FECHA: Recientes <span class="opacity-40">↓</span></span>
                            </a>
                            <a href={`?status=${statusFilter || 'all'}&search=${searchQuery || ''}&startDate=${startDate}&endDate=${endDate}&sort=oldest`} class={`block px-5 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all ${sortOrder === 'oldest' ? 'bg-white text-black' : 'text-zinc-400 hover:bg-white/5 hover:text-white'}`}>
                                <span class="flex items-center justify-between gap-4">FECHA: Antiguos <span class="opacity-40">↑</span></span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            {activeFiltersCount > 0 && (
                <a href="/admin/returns" class="flex items-center justify-center h-14 w-14 bg-red-500/10 border-2 border-red-500/50 text-red-500 rounded-xl hover:bg-red-500 hover:text-white transition-all shadow-[0_0_20px_rgba(239,68,68,0.2)]" title="Limpiar Filtros">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </a>
            )}
        </div>
    </div>
  </div>

  <!-- Returns Insights -->
  <div class="px-8 mb-12 grid grid-cols-2 lg:grid-cols-4 gap-8">
    <div class="bg-white p-6 rounded-3xl border border-black/5 shadow-sm">
        <p class="text-[8px] font-black text-zinc-400 uppercase tracking-[0.2em] mb-2">Total Solicitudes</p>
        <p class="text-2xl font-black text-black">{filteredReturns.length}</p>
    </div>
    <div class="bg-white p-6 rounded-3xl border border-black/5 shadow-sm">
        <p class="text-[8px] font-black text-zinc-400 uppercase tracking-[0.2em] mb-2">Aprobadas</p>
        <p class="text-2xl font-black text-black">{filteredReturns.filter(r => r.status === 'approved').length}</p>
    </div>
    <div class="bg-white p-6 rounded-3xl border border-black/5 shadow-sm">
        <p class="text-[8px] font-black text-zinc-400 uppercase tracking-[0.2em] mb-2">Rechazadas</p>
        <p class="text-2xl font-black text-black">{filteredReturns.filter(r => r.status === 'rejected').length}</p>
    </div>
    <div class="bg-white p-6 rounded-3xl border border-black/5 shadow-sm border-l-amber-500 border-l-4">
        <p class="text-[8px] font-black text-amber-500 uppercase tracking-[0.2em] mb-2">Pendientes</p>
        <p class="text-2xl font-black text-black">{filteredReturns.filter(r => r.status === 'pending').length}</p>
    </div>
  </div>

  <!-- Results Info -->
  <div class="px-4 mb-6 flex items-center justify-between">
    <p class="text-[10px] font-black text-zinc-400 uppercase tracking-[0.3em]">
        Registros: <span class="text-black">{filteredReturns.length}</span> registros detectados
    </p>
    {searchQuery && (
        <div class="flex items-center gap-2 px-4 py-2 bg-zinc-800 text-white rounded-full text-[9px] font-black uppercase tracking-widest animate-fade-in-up">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            FILTRADO: {(searchQuery || '').toUpperCase()}
        </div>
    )}
  </div>

    {fetchError && (
        <div class="p-8 bg-red-50 border-2 border-red-100 rounded-3xl text-center">
            <p class="text-red-600 font-black uppercase tracking-widest text-sm">Error de sincronización: {fetchError.message}</p>
        </div>
    )}

    <!-- Returns List: Industrial Table -->
    <div class="bg-white rounded-[3rem] border border-zinc-200/60 shadow-xl overflow-hidden mb-20 animate-fade-in">
        <div class="overflow-x-auto min-h-[400px]">
            <table class="w-full text-left border-collapse">
                <thead class="bg-zinc-50 border-b-2 border-zinc-100 sticky top-0 z-10">
                    <tr>
                        <th class="px-8 py-4 text-[10px] font-black text-black uppercase tracking-[0.2em]">ID Solicitud</th>
                        <th class="px-8 py-4 text-[10px] font-black text-zinc-400 uppercase tracking-[0.2em]">Cliente</th>
                        <th class="px-8 py-4 text-[10px] font-black text-zinc-400 uppercase tracking-[0.2em]">Razón / Items</th>
                        <th class="px-8 py-4 text-[10px] font-black text-zinc-400 uppercase tracking-[0.2em]">Estado</th>
                        <th class="px-8 py-4 text-[10px] font-black text-zinc-400 uppercase tracking-[0.2em]">Fecha</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-zinc-100">
                    {filteredReturns.length > 0 ? (
                        filteredReturns.map((ret) => (
                            <tr class="group hover:bg-zinc-50/80 transition-all duration-300">
                                <td class="px-8 py-5 align-top">
                                    <div class="flex items-center gap-3">
                                        <div class={`w-2 h-10 rounded-full ${
                                            ret.status === 'approved' ? 'bg-emerald-500' : 
                                            ret.status === 'rejected' ? 'bg-red-500' : 
                                            'bg-amber-500'
                                        }`}></div>
                                        <div>
                                            <span class="block text-xs font-black text-black uppercase tracking-widest font-mono">#{ret.id.slice(0, 8)}</span>
                                            <span class="text-[9px] font-bold text-zinc-400 uppercase tracking-widest block mt-0.5">
                                                Ref: #{ret.order_id.slice(0, 8)}
                                            </span>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-8 py-5 align-top">
                                    <div class="max-w-[200px]">
                                        <p class="text-[10px] font-black text-black uppercase truncate">{ret.profiles?.full_name || 'Usuario'}</p>
                                        <p class="text-[8px] font-bold text-zinc-300 uppercase truncate mt-0.5">{ret.profiles?.email}</p>
                                    </div>
                                </td>
                                <td class="px-8 py-5 align-top">
                                    <div class="mb-2">
                                        <span class="px-2 py-0.5 bg-zinc-100 rounded text-[9px] font-black uppercase tracking-widest text-zinc-500">
                                            {returnReasons[ret.reason] || ret.reason}
                                        </span>
                                    </div>
                                    <div class="flex -space-x-2 overflow-hidden py-1">
                                        {ret.return_request_items?.slice(0, 4).map((item: any) => (
                                            <div class="w-8 h-8 rounded-full border-2 border-white bg-zinc-100 overflow-hidden relative" title={item.order_items?.product_name}>
                                                {item.order_items?.product_image ? (
                                                    <img src={item.order_items.product_image} class="w-full h-full object-cover" />
                                                ) : (
                                                    <div class="w-full h-full flex items-center justify-center text-[8px] font-bold text-zinc-300">No img</div>
                                                )}
                                            </div>
                                        ))}
                                    </div>
                                </td>
                                <td class="px-8 py-5 align-top">
                                    <div class="relative w-40" id={`status-capture-${ret.id}`}>
                                        <button 
                                            type="button" 
                                            class={`status-dropdown-btn w-full px-3 py-1.5 rounded-lg flex items-center justify-between text-[8px] font-black uppercase tracking-widest border transition-all
                                                ${ret.status === 'approved' ? 'bg-emerald-50 text-emerald-600 border-emerald-100 hover:bg-emerald-100' : 
                                                  ret.status === 'rejected' ? 'bg-red-50 text-red-600 border-red-100 hover:bg-red-100' : 
                                                  'bg-amber-50 text-amber-600 border-amber-100 hover:bg-amber-100'}`}
                                            data-return-id={ret.id}
                                        >
                                            <span>{statusLabels[ret.status] || ret.status}</span>
                                            <svg class="w-3 h-3 opacity-50 status-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                        </button>

                                        <div class="status-dropdown-menu absolute top-full left-0 right-0 mt-1 bg-white border border-zinc-100 rounded-lg shadow-xl hidden z-50 overflow-hidden">
                                            {['pending', 'approved', 'rejected'].map(status => (
                                                <button
                                                    class={`status-option-btn w-full text-left px-4 py-2 text-[8px] font-bold uppercase tracking-widest hover:bg-zinc-50 transition-colors
                                                        ${ret.status === status ? 'bg-black text-white hover:bg-black' : 'text-zinc-500'}`}
                                                    data-return-id={ret.id}
                                                    data-status={status}
                                                    data-label={statusLabels[status]}
                                                >
                                                    {statusLabels[status as keyof typeof statusLabels]}
                                                </button>
                                            ))}
                                        </div>
                                    </div>
                                </td>
                                <td class="px-8 py-5 align-top">
                                     <span class="text-[9px] font-bold text-zinc-400 uppercase tracking-widest">
                                        {new Date(ret.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: '2-digit' })}
                                    </span>
                                    <span class="block text-[8px] font-bold text-zinc-300 uppercase tracking-widest mt-0.5">
                                        {new Date(ret.created_at).toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' })}
                                    </span>
                                </td>
                            </tr>
                        ))
                    ) : (
                        <tr>
                            <td colspan="6" class="p-20 text-center">
                                <div class="flex flex-col items-center gap-4 opacity-50">
                                    <svg class="w-12 h-12 text-zinc-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                                    <p class="text-[10px] font-black text-zinc-400 uppercase tracking-widest">Sin solicitudes registradas</p>
                                </div>
                            </td>
                        </tr>
                    )}
                </tbody>
            </table>
        </div>
    </div>

  <script>
    let isInitialized = false;

    function customConfirm(title: string, message: string, variant: 'danger' | 'warning' | 'info' = 'info'): Promise<boolean> {
        return new Promise((resolve) => {
            const event = new CustomEvent('open-confirm-modal', {
                detail: {
                    title,
                    message,
                    variant,
                    confirmText: 'CONFIRMAR',
                    cancelText: 'CANCELAR',
                    onConfirm: () => resolve(true),
                    onCancel: () => resolve(false)
                }
            });
            window.dispatchEvent(event);
        });
    }

    function initPage() {
        if (isInitialized) return;

        // --- GLOBAL EVENT DELEGATION ---
        document.addEventListener('click', async (e) => {
            const target = e.target as HTMLElement;

            // 1. TOP-LEVEL FILTERS (Status, Date, Sort)
            const filterBtn = target.closest('#ret-status-btn, #ret-sort-btn, #ret-date-btn');
            if (filterBtn) {
                e.preventDefault();
                e.stopPropagation();
                const idPrefix = filterBtn.id.replace('ret-', '').replace('-btn', '');
                const menuId = `ret-${idPrefix}-menu`;
                const arrowId = `ret-${idPrefix}-arrow`;
                
                const menu = document.getElementById(menuId);
                const arrow = document.getElementById(arrowId);
                
                document.querySelectorAll('[id^="ret-"][id$="-menu"]').forEach(m => {
                    if (m !== menu) m.classList.add('hidden');
                });
                document.querySelectorAll('[id^="ret-"][id$="-arrow"]').forEach(a => {
                    if (a !== arrow) a.classList.remove('rotate-180');
                });

                menu?.classList.toggle('hidden');
                arrow?.classList.toggle('rotate-180');
                // Close other Status Dropdowns inside table
                document.querySelectorAll('.status-dropdown-menu').forEach(m => m.classList.add('hidden'));
                return;
            }

            // 2. TABLE STATUS DROPDOWN TOGGLE
            const statusDropdownBtn = target.closest('.status-dropdown-btn');
            if (statusDropdownBtn) {
                 e.preventDefault();
                 e.stopPropagation();
                 
                 // Close all other status menus
                 document.querySelectorAll('.status-dropdown-menu').forEach(m => {
                    if (m.parentElement !== statusDropdownBtn.parentElement) {
                        m.classList.add('hidden');
                    }
                 });

                 // Toggle this one
                 const menu = statusDropdownBtn.nextElementSibling;
                 menu?.classList.toggle('hidden');
                 return;
            }

            // 3. STATUS UPDATE ACTION (Option Click)
            const statusOptionBtn = target.closest('.status-option-btn') as HTMLButtonElement;
            if (statusOptionBtn) {
                e.preventDefault();
                e.stopPropagation();
                
                const id = statusOptionBtn.dataset.returnId;
                const status = statusOptionBtn.dataset.status;
                const label = statusOptionBtn.dataset.label;
                
                // Hide menu
                statusOptionBtn.closest('.status-dropdown-menu')?.classList.add('hidden');

                const confirmed = await customConfirm(
                    'CAMBIAR ESTADO',
                    `¿CONFIRMAR CAMBIO DE ESTADO A ${status?.toUpperCase() || ''}?`,
                    status === 'rejected' ? 'danger' : 'info'
                );
                
                if (!confirmed) return;

                try {
                    const response = await fetch('/api/admin/returns/update-status', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ returnId: id, status })
                    });

                    const data = await response.json();
                    if (!response.ok || !data.success) throw new Error(data.message);

                    (window as any).showIndustrialAlert('ESTADO ACTUALIZADO', 'success');
                    // Small delay to show alert then reload
                    setTimeout(() => window.location.reload(), 1000);
                } catch (err: any) {
                    (window as any).showIndustrialAlert('Error al actualizar: ' + err.message, 'error');
                }
                return;
            }

            // Global close
            document.querySelectorAll('[id^="ret-"][id$="-menu"]').forEach(m => m.classList.add('hidden'));
            document.querySelectorAll('[id^="ret-"][id$="-arrow"]').forEach(a => a.classList.remove('rotate-180'));
            document.querySelectorAll('.status-dropdown-menu').forEach(m => m.classList.add('hidden'));
        });

        isInitialized = true;
    }
    document.addEventListener('astro:page-load', initPage);
  </script>

  <style>
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-fade-in-up {
        animation: fadeInUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    
    /* Custom Scrollbar for longer tables */
    .overflow-x-auto::-webkit-scrollbar {
        height: 6px;
    }
    .overflow-x-auto::-webkit-scrollbar-track {
        background: transparent;
    }
    .overflow-x-auto::-webkit-scrollbar-thumb {
        background-color: rgba(0,0,0,0.1);
        border-radius: 3px;
    }
    .overflow-x-auto::-webkit-scrollbar-thumb:hover {
        background-color: rgba(0,0,0,0.2);
    }
  </style>
  <ConfirmationModal client:load />
</AdminLayout>
