---
import PublicLayout from '@layouts/PublicLayout.astro';
import { ui, defaultLang, useTranslations } from '@lib/i18n';

const lang = Astro.locals.lang || defaultLang;
const t = useTranslations(lang as keyof typeof ui);
---

<PublicLayout title={t('shipping.title')}>
  <div class="container-custom py-24 min-h-[60vh]">
    <div class="max-w-5xl mx-auto">
        {/* Header Section */}
        <header class="mb-20">
            <div class="flex items-center gap-4 mb-6">
                <span class="px-3 py-1 bg-[#202020] text-white text-[10px] font-mono font-black uppercase tracking-[0.3em]">{t('shipping.header.tag')}</span>
                <div class="h-[2px] flex-1 bg-black/10"></div>
            </div>
            <h1 class="text-6xl md:text-8xl font-urban font-black uppercase tracking-tighter text-black leading-[0.85] mb-6" set:html={t('shipping.header.title').replace(' ', '<br/>')}>
            </h1>
            <p class="text-zinc-500 font-mono text-sm uppercase tracking-widest max-w-xl">
                {t('shipping.header.subtitle')}
            </p>
        </header>

        {/* Shipping Options Grid */}
        <section class="mb-24">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="p-8 border-4 border-black bg-white group hover:bg-zinc-50 transition-all flex flex-col justify-between h-[320px]">
                    <div>
                        <div class="flex justify-between items-start mb-6">
                            <span class="text-[10px] font-mono font-black px-2 py-1 bg-zinc-100 text-zinc-500">OP_01</span>
                            <svg class="w-6 h-6 text-zinc-300 group-hover:text-black transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
                        </div>
                        <h3 class="text-2xl font-black uppercase tracking-tighter mb-2">{t('shipping.op1.title')}</h3>
                        <p class="text-xs font-bold text-zinc-400 uppercase tracking-widest mb-6">{t('shipping.op1.tag')}</p>
                        <p class="text-zinc-500 text-sm font-bold uppercase tracking-wider leading-relaxed">
                            {t('shipping.op1.desc')}
                        </p>
                    </div>
                    <div class="flex justify-between items-end">
                        <div class="flex flex-col">
                            <span class="text-[10px] text-zinc-400 font-black">{t('shipping.labels.estimated')}</span>
                            <span class="text-xl font-urban font-black">{t('shipping.op1.time')}</span>
                        </div>
                        <span class="text-2xl font-urban font-black italic">4,95€</span>
                    </div>
                </div>

                <div class="p-8 border-4 border-black bg-black text-white group hover:bg-[#202020] transition-all flex flex-col justify-between h-[320px] shadow-2xl shadow-black/20">
                    <div>
                        <div class="flex justify-between items-start mb-6">
                            <span class="text-[10px] font-mono font-black px-2 py-1 bg-white/10 text-zinc-400">OP_02</span>
                            <div class="w-2 h-2 bg-brand-red rounded-full animate-pulse"></div>
                        </div>
                        <h3 class="text-2xl font-black uppercase tracking-tighter mb-2 italic">{t('shipping.op2.title')}</h3>
                        <p class="text-xs font-bold text-zinc-500 uppercase tracking-widest mb-6">{t('shipping.op2.tag')}</p>
                        <p class="text-zinc-400 text-sm font-bold uppercase tracking-wider leading-relaxed">
                            {t('shipping.op2.desc')}
                        </p>
                    </div>
                    <div class="flex justify-between items-end">
                        <div class="flex flex-col">
                            <span class="text-[10px] text-zinc-500 font-black">{t('shipping.labels.estimated')}</span>
                            <span class="text-xl font-urban font-black">{t('shipping.op2.time')}</span>
                        </div>
                        <span class="text-2xl font-urban font-black italic">7,95€</span>
                    </div>
                </div>

                <div class="p-8 border-4 border-black bg-white group hover:bg-zinc-50 transition-all flex flex-col justify-between h-[320px]">
                    <div>
                        <div class="flex justify-between items-start mb-6">
                            <span class="text-[10px] font-mono font-black px-2 py-1 bg-zinc-100 text-zinc-500">OP_03</span>
                            <svg class="w-6 h-6 text-zinc-300 group-hover:text-black transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"></path></svg>
                        </div>
                        <h3 class="text-2xl font-black uppercase tracking-tighter mb-2">{t('shipping.op3.title')}</h3>
                        <p class="text-xs font-bold text-zinc-400 uppercase tracking-widest mb-6">{t('shipping.op3.tag')}</p>
                        <p class="text-zinc-500 text-sm font-bold uppercase tracking-wider leading-relaxed">
                            {t('shipping.op3.desc')}
                        </p>
                    </div>
                    <div class="flex justify-between items-end">
                        <div class="flex flex-col">
                            <span class="text-[10px] text-zinc-400 font-black">{t('shipping.labels.estimated')}</span>
                            <span class="text-xl font-urban font-black">{t('shipping.op3.time')}</span>
                        </div>
                        <span class="text-2xl font-urban font-black italic">9,95€</span>
                    </div>
                </div>
            </div>
        </section>

        <div class="grid lg:grid-cols-3 gap-16">
            <div class="lg:col-span-2 space-y-20">
                {/* Logistics Info */}
                <section>
                    <div class="flex items-center gap-3 mb-10 border-b-4 border-black pb-4">
                        <span class="w-3 h-3 bg-black rounded-full"></span>
                        <h2 class="text-3xl font-black uppercase tracking-tighter">{t('shipping.order.title')}</h2>
                    </div>

                    <div class="space-y-12">
                        <div class="flex gap-8 group">
                            <span class="text-4xl font-urban font-black text-zinc-200 group-hover:text-black transition-colors shrink-0">01</span>
                            <div>
                                <h4 class="text-[12px] font-black uppercase tracking-[0.2em] mb-2 text-zinc-400">{t('shipping.order.step1.title')}</h4>
                                <p class="text-xl font-urban font-bold leading-snug">{t('shipping.order.step1.desc')}</p>
                            </div>
                        </div>
                        <div class="flex gap-8 group">
                            <span class="text-4xl font-urban font-black text-zinc-200 group-hover:text-black transition-colors shrink-0">02</span>
                            <div>
                                <h4 class="text-[12px] font-black uppercase tracking-[0.2em] mb-2 text-zinc-400">{t('shipping.order.step2.title')}</h4>
                                <p class="text-xl font-urban font-bold leading-snug">{t('shipping.order.step2.desc')}</p>
                            </div>
                        </div>
                        <div class="flex gap-8 group">
                            <span class="text-4xl font-urban font-black text-zinc-200 group-hover:text-black transition-colors shrink-0">03</span>
                            <div>
                                <h4 class="text-[12px] font-black uppercase tracking-[0.2em] mb-2 text-zinc-400">{t('shipping.order.step3.title')}</h4>
                                <p class="text-xl font-urban font-bold leading-snug italic">{t('shipping.order.step3.desc')}</p>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            {/* Sidebar info */}
            <div class="space-y-8">
                <div class="p-8 bg-zinc-50 border-2 border-black rounded-[2rem] relative">
                    <h3 class="text-xl font-black uppercase mb-6 italic">{t('shipping.sidebar.tracking.title')}</h3>
                    <p class="text-[11px] font-bold uppercase tracking-wider text-zinc-500 mb-8 leading-relaxed">
                        {t('shipping.sidebar.tracking.desc')}
                    </p>
                    <div class="space-y-3">
                        <div class="h-2 w-full bg-zinc-200 rounded-full overflow-hidden">
                            <div class="h-full w-[65%] bg-black"></div>
                        </div>
                        <div class="flex justify-between text-[8px] font-black uppercase tracking-[0.2em]">
                            <span>ORDER</span>
                            <span>SHIPPED</span>
                            <span class="text-zinc-300">DELIVERED</span>
                        </div>
                    </div>
                </div>

                <div class="bg-[#202020] text-white p-8 rounded-[2rem] border border-white/5 overflow-hidden relative">
                    <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-white/5 rotate-45"></div>
                    <h4 class="font-black uppercase text-xl mb-4 italic">{t('shipping.sidebar.free.title')}</h4>
                    <p class="text-xs text-zinc-400 font-black uppercase tracking-widest mb-6 leading-relaxed">
                        {t('shipping.sidebar.free.desc').replace('{amount}', '50')}
                    </p>
                </div>

                <div class="p-8 border-2 border-zinc-200 rounded-[2rem]">
                    <h4 class="font-black uppercase text-sm mb-4">{t('shipping.sidebar.help.title')}</h4>
                    <a href="/customer-service" class="group flex items-center justify-between font-black uppercase tracking-widest text-[9px]">
                        {t('common.help_center')}
                        <svg class="w-4 h-4 transition-transform group-hover:translate-x-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
  </div>
</PublicLayout>

