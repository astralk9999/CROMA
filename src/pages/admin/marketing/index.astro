                            <div class="space-y-4">
                                <label class="text-[11px] font-black text-zinc-400 uppercase tracking-widest flex items-center gap-3 px-2">
                                    <span class="w-1.5 h-1.5 bg-black rounded-full"></span> 02. Asunto del Email
