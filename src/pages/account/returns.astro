---
import PublicLayout from '@layouts/PublicLayout.astro';
import { ui, defaultLang, useTranslations } from '@lib/i18n';
import { supabaseAdmin } from '@lib/supabase-admin';

const lang = Astro.locals.lang || defaultLang;
const t = useTranslations(lang as keyof typeof ui);

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/auth/login?redirect=/account/returns');
}

// Fetch return requests for this user
const { data: returns } = await supabaseAdmin
  .from('return_requests')
  .select(`
    *,
    orders (id, total_amount, created_at),
    return_request_items (
        quantity,
        order_items (
            product_name,
            size,
            product_image
        )
    )
  `)
  .eq('user_id', user.id)
  .order('created_at', { ascending: false });

const getStatusLabel = (status: string) => {
    const keys: Record<string, string> = {
        'pending': 'account.returns.status.pending',
        'approved': 'account.returns.status.approved',
        'rejected': 'account.returns.status.rejected',
        'completed': 'account.returns.status.completed'
    };
    return t(keys[status] as any || status);
}

const formatDate = (date: string) => new Date(date).toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-US', { 
    day: 'numeric', month: 'long', year: 'numeric' 
});
---

<PublicLayout title={t('account.returns') || ''}>
  <section class="container-custom py-16 min-h-screen bg-white">
    <div class="max-w-6xl mx-auto px-4 md:px-0">
      {/* Mega Header Section */}
      <div class="flex flex-col mb-14 gap-6">
          <div class="flex items-center gap-4">
              <span class="w-16 h-0.5 bg-zinc-400"></span>
              <span class="text-xs font-bold uppercase tracking-[0.5em] text-zinc-500">{t('account.returns.terminal')}</span>
          </div>
          
          <h1 class="text-6xl md:text-8xl lg:text-9xl font-urban font-black tracking-tighter uppercase leading-[0.8] italic">
              <span class="text-zinc-900">{t('account.returns.header.main_p1')}</span> <span class="text-zinc-400">{t('account.returns.header.main_p2')}</span>
          </h1>

          <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-zinc-300 pb-8">
              <div class="max-w-2xl">
                  <p class="text-zinc-600 font-bold text-lg md:text-xl uppercase tracking-tight leading-snug">
                      {t('account.returns.header.sub')}
                  </p>
              </div>
              <a href="/account/orders" class="group flex items-center gap-3 text-sm font-bold uppercase tracking-[0.2em] text-zinc-600 hover:text-zinc-900 transition-all px-8 py-4 border border-zinc-300 rounded-full hover:bg-zinc-50 hover:shadow-xl hover:shadow-zinc-200/50">
                  <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
                  {t('account.orders')}
              </a>
          </div>
      </div>

      {!returns || returns.length === 0 ? (
        <div class="bg-white rounded-[3rem] border border-zinc-300 p-24 text-center shadow-2xl shadow-zinc-200/40 relative overflow-hidden group">
             <div class="w-24 h-24 bg-zinc-100 rounded-full flex items-center justify-center mx-auto mb-10 text-zinc-300">
                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M16 15v-1a4 4 0 00-4-4H8m0 0l3 3m-3-3l3-3m9 14V5a2 2 0 00-2-2H6a2 2 0 00-2 2v16l4-2 4 2 4-2 4 2z" /></svg>
             </div>
             <h2 class="text-5xl font-urban font-black text-zinc-900 mb-6 uppercase italic">{t('account.returns.empty.title')}</h2>
             <p class="text-zinc-500 font-bold uppercase tracking-[0.2em] mb-12">{t('account.returns.empty.desc')}</p>
             <a href="/account/orders" class="inline-block px-12 py-5 bg-zinc-900 text-white text-md font-bold uppercase tracking-widest rounded-full hover:bg-black transition-all shadow-xl hover:shadow-2xl">
                {t('account.orders')}
             </a>
        </div>
      ) : (
        <div class="space-y-16">
            <div class="flex items-center gap-6 mb-6 font-urban opacity-80">
                <h2 class="text-2xl font-black text-zinc-800 uppercase tracking-[0.3em] italic">{t('account.returns.active_audits')}</h2>
                <div class="h-px flex-1 bg-zinc-300"></div>
                <span class="text-zinc-500 font-bold uppercase tracking-widest text-xs">{returns.length} {t('account.returns.tickets')}</span>
            </div>

            <div class="grid gap-12">
                {returns.map(ret => (
                    <article class="bg-white rounded-[2.5rem] border border-zinc-300 shadow-2xl shadow-zinc-200/40 overflow-hidden transition-all duration-700">
                        {/* Status Header Block — same style as orders */}
                        <div class="bg-zinc-900 py-6 px-8 flex flex-wrap items-center justify-between gap-6 relative">
                            <div class="flex items-center gap-12">
                                <div class="flex flex-col">
                                    <span class="text-zinc-500 font-bold text-[9px] uppercase tracking-[0.4em] mb-1">{t('account.returns.label.ticket_id')}</span>
                                    <span class="font-mono text-white text-sm font-bold tracking-tighter">#{(ret.id?.slice(0, 16) || '').toUpperCase()}</span>
                                </div>
                                <div class="hidden md:flex flex-col border-l border-white/10 pl-12">
                                    <span class="text-zinc-500 font-bold text-[9px] uppercase tracking-[0.4em] mb-1">{t('account.returns.label.audit_date')}</span>
                                    <span class="font-bold text-white text-sm uppercase">{formatDate(ret.created_at)}</span>
                                </div>
                            </div>

                            <div class="flex items-center gap-6">
                                <div class="text-right">
                                    <p class="text-zinc-500 font-bold text-[9px] uppercase tracking-[0.3em] mb-1">{t('account.returns.label.reason')}</p>
                                    <p class="text-sm font-black uppercase tracking-widest text-white">{ret.reason}</p>
                                </div>
                                <span class={`px-6 py-2 text-[10px] font-black uppercase tracking-[0.2em] rounded-full ${
                                    ret.status === 'pending' ? 'bg-amber-400 text-amber-950' :
                                    ret.status === 'approved' ? 'bg-emerald-400 text-emerald-950' :
                                    ret.status === 'rejected' ? 'bg-red-500 text-white' :
                                    'bg-zinc-700 text-white'
                                }`}>
                                    {(getStatusLabel(ret.status) || '').toUpperCase()}
                                </span>
                            </div>
                        </div>

                        <div class="grid lg:grid-cols-[1fr_360px]">
                            {/* Items Area — matches orders layout */}
                            <div class="p-8 md:p-10 space-y-10 lg:border-r border-zinc-200">
                                <div class="space-y-6">
                                    {ret.return_request_items?.map((item: any) => {
                                        const orderItem = Array.isArray(item.order_items) ? item.order_items[0] : item.order_items;
                                        return (
                                            <div class="flex items-center gap-8 md:gap-12 group/item">
                                                <div class="relative w-24 h-24 md:w-32 md:h-32 flex-shrink-0 bg-white border border-zinc-200 rounded-2xl overflow-hidden group-hover/item:shadow-2xl group-hover/item:shadow-zinc-200 transition-all duration-500">
                                                    {orderItem?.product_image ? (
                                                        <img src={orderItem.product_image} class="w-full h-full object-cover grayscale group-hover/item:grayscale-0 transition-all duration-1000 group-hover/item:scale-110" />
                                                    ) : (
                                                        <div class="w-full h-full bg-zinc-50 italic flex items-center justify-center font-bold text-zinc-300">{t('account.orders.no_img')}</div>
                                                    )}
                                                </div>
                                                <div class="flex-1 space-y-3">
                                                    <div class="flex justify-between items-start">
                                                        <h4 class="text-2xl md:text-3xl font-urban font-black text-zinc-900 uppercase italic leading-[0.9] tracking-tighter">
                                                            {orderItem?.product_name || 'Item Desconocido'}
                                                        </h4>
                                                    </div>
                                                    <div class="flex flex-wrap gap-4 pt-2">
                                                        <span class="px-3 py-1 bg-zinc-100 text-zinc-600 text-[10px] font-bold uppercase tracking-[0.2em] rounded-lg">{t('account.orders.size_label')}_{orderItem?.size || 'N/A'}</span>
                                                        <span class="px-3 py-1 border border-zinc-200 text-zinc-400 text-[10px] font-bold uppercase tracking-[0.2em] rounded-lg">{t('account.orders.qty_label')}_0{item.quantity}</span>
                                                    </div>
                                                </div>
                                            </div>
                                        );
                                    })}
                                </div>

                                {/* Return Progress Tracker — mirrors the logistics flow in orders */}
                                <div class="pt-8 border-t border-zinc-100">
                                    <div class="flex flex-col gap-4">
                                        <div class="flex justify-between items-end">
                                            <div class="flex items-center gap-3">
                                                <div class="w-2 h-2 rounded-full bg-zinc-900"></div>
                                                <h4 class="text-xs font-bold text-zinc-900 uppercase tracking-[0.4em]">{t('account.returns.audit_flow') || 'Audit Flow'}</h4>
                                            </div>
                                            <span class="text-sm font-bold text-zinc-400 uppercase italic tracking-tighter">
                                                {ret.status === 'pending' ? `${t('account.orders.step') || 'Step'}_01` : ret.status === 'approved' ? `${t('account.orders.step') || 'Step'}_02` : ret.status === 'completed' ? `${t('account.orders.step') || 'Step'}_03` : `${t('account.orders.step') || 'Step'}_01`} / 03
                                            </span>
                                        </div>
                                        <div class="h-3 bg-zinc-50 rounded-full border border-zinc-200 p-0.5 relative">
                                            <div 
                                                class={`h-full rounded-full transition-all duration-1000 ease-in-out relative overflow-hidden ${
                                                    ret.status === 'rejected' ? 'bg-red-500' : 'bg-zinc-900'
                                                }`}
                                                style={{ width: ret.status === 'completed' ? '100%' : ret.status === 'approved' ? '66%' : ret.status === 'rejected' ? '100%' : '25%' }}
                                            >
                                                <div class="absolute inset-0 bg-[linear-gradient(45deg,rgba(255,255,255,0.05)_25%,transparent_25%,transparent_50%,rgba(255,255,255,0.05)_50%,rgba(255,255,255,0.05)_75%,transparent_75%,transparent)] bg-[length:20px_20px] animate-shimmer"></div>
                                            </div>
                                        </div>
                                        <div class="grid grid-cols-3 gap-2 text-[10px] font-bold text-zinc-300 uppercase tracking-tight text-center italic">
                                            <span class={ret.status === 'pending' ? 'text-zinc-900' : ''}>{t('account.returns.status.pending')}</span>
                                            <span class={ret.status === 'approved' ? 'text-zinc-900' : ''}>{t('account.returns.status.approved')}</span>
                                            <span class={ret.status === 'completed' ? 'text-zinc-900' : ret.status === 'rejected' ? 'text-red-600' : ''}>{ret.status === 'rejected' ? t('account.returns.status.rejected') : t('account.returns.status.completed')}</span>
                                        </div>
                                    </div>
                                </div>

                                {/* Reason Details — compact */}
                                {ret.details && (
                                    <div class="pt-8 border-t border-zinc-100">
                                        <p class="text-[10px] font-bold text-zinc-400 uppercase tracking-[0.5em] mb-4">{t('account.returns.label.reason')}</p>
                                        <p class="text-lg text-zinc-700 leading-relaxed italic font-bold tracking-tight">"{ret.details}"</p>
                                    </div>
                                )}
                            </div>

                            {/* Data Sidebar — matches orders finance sidebar */}
                            <div class="p-6 md:p-8 bg-zinc-50 flex flex-col justify-between">
                                <div class="space-y-8">
                                    <div class="p-6 md:p-8 bg-white border border-zinc-200 rounded-[2rem] shadow-2xl shadow-zinc-200/50 relative overflow-hidden group/pod">
                                        <div class="absolute top-0 right-0 p-4 opacity-[0.03] pointer-events-none group-hover/pod:scale-110 transition-transform text-black">
                                            <svg class="w-16 h-16" fill="currentColor" viewBox="0 0 24 24"><path d="M11 15h2v2h-2zm0-8h2v6h-2zm.99-5C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/></svg>
                                        </div>
                                        <p class="text-zinc-400 font-bold text-[10px] uppercase tracking-[0.3em] mb-5 pb-3 border-b border-zinc-100 font-mono">{t('account.returns.support_data')}</p>
                                        <div class="space-y-4">
                                            <div>
                                                <p class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest mb-1">{t('account.returns.origin_order')}</p>
                                                <p class="text-sm font-black text-zinc-900 font-mono">#{(ret.order_id?.slice(0, 12) || '').toUpperCase()}</p>
                                            </div>
                                            <div>
                                                <p class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest mb-1">{t('account.returns.returned_units')}</p>
                                                <p class="text-sm font-black text-zinc-900">{ret.return_request_items?.length < 10 ? `0${ret.return_request_items?.length}` : ret.return_request_items?.length} {t('account.returns.units')}</p>
                                            </div>
                                            <div class="pt-4 mt-2 border-t border-zinc-100">
                                                <p class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest mb-2">{t('account.returns.total_amount')}</p>
                                                <p class="text-3xl font-black text-zinc-900 tracking-tighter">{Number(ret.orders?.total_amount).toFixed(2)}€</p>
                                            </div>
                                        </div>
                                    </div>

                                    {/* Evidence Images */}
                                    {ret.images?.length > 0 && (
                                        <div class="space-y-4">
                                            <p class="text-[10px] font-bold text-zinc-400 uppercase tracking-[0.4em] px-2 text-center">{t('account.returns.visual_evidence')}</p>
                                            <div class="grid grid-cols-2 gap-4">
                                                {ret.images.map((img: string) => (
                                                    <a href={img} target="_blank" class="block aspect-square border border-zinc-200 rounded-2xl overflow-hidden bg-white group/img hover:shadow-xl transition-all">
                                                        <img src={img} class="w-full h-full object-cover grayscale group-hover/img:grayscale-0 transition-all duration-700 group-hover/img:scale-110" />
                                                    </a>
                                                ))}
                                            </div>
                                        </div>
                                    )}

                                    {/* Admin Notes */}
                                    {ret.admin_notes && (
                                        <div class="p-6 bg-zinc-900 rounded-2xl border-l-4 border-red-500">
                                            <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.3em] mb-4">{t('account.returns.admin_response_report')}</p>
                                            <p class="text-sm font-bold italic text-zinc-200 leading-relaxed">"{ret.admin_notes}"</p>
                                        </div>
                                    )}
                                </div>
                            </div>
                        </div>
                    </article>
                ))}
            </div>
        </div>
      )}
    </div>
  </section>
</PublicLayout>
