
---
const currentLang = Astro.locals.lang || 'es';
---

<div class="flex items-center gap-1 text-[10px] font-black uppercase tracking-widest bg-gray-100/50 px-2 py-1 rounded-md border border-gray-200">
  <button 
    data-lang="es" 
    class={`px-1.5 py-0.5 rounded transition-colors ${currentLang === 'es' ? 'bg-black text-white' : 'text-gray-400 hover:text-black'}`}
  >
    ES
  </button>
  <span class="text-gray-300">/</span>
  <button 
    data-lang="en" 
    class={`px-1.5 py-0.5 rounded transition-colors ${currentLang === 'en' ? 'bg-black text-white' : 'text-gray-400 hover:text-black'}`}
  >
    EN
  </button>
</div>

<script>
  function initLanguageToggle() {
    const buttons = document.querySelectorAll('[data-lang]');
    
    buttons.forEach(btn => {
      // Remove old listeners by cloning
      const newBtn = btn.cloneNode(true);
      btn.parentNode?.replaceChild(newBtn, btn);
      
      newBtn.addEventListener('click', () => {
        const lang = newBtn.getAttribute('data-lang');
        document.cookie = `preferred_language=${lang}; path=/; max-age=31536000; SameSite=Lax`;
        window.location.reload();
      });
    });
  }

  document.addEventListener('astro:page-load', initLanguageToggle);
</script>
