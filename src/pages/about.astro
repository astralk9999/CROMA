---
import PublicLayout from '@layouts/PublicLayout.astro';
import { ui, defaultLang, useTranslations } from '@lib/i18n';

const lang = Astro.locals.lang || defaultLang;
const t = useTranslations(lang as keyof typeof ui);
---

<PublicLayout title={t('about.title')}>
  <div class="container-custom py-24 min-h-[60vh]">
    <div class="max-w-5xl mx-auto">
        {/* Header Section */}
        <header class="mb-32">
            <div class="flex items-center gap-4 mb-8">
                <span class="px-3 py-1 bg-[#202020] text-white text-[10px] font-mono font-black uppercase tracking-[0.3em]">{t('about.header.tag')}</span>
                <div class="h-[2px] flex-1 bg-black/10"></div>
            </div>
            <h1 class="text-7xl md:text-[10rem] font-urban font-black uppercase tracking-tighter text-black leading-[0.75] mb-12" set:html={t('about.header.title').replace(' ', '<br/>')}>
            </h1>
            <div class="grid md:grid-cols-2 gap-12 items-end">
                <p class="text-xl font-urban font-bold uppercase tracking-tight leading-tight text-zinc-600">
                    {t('about.header.subtitle')}
                </p>
                <div class="flex flex-col gap-2">
                    <span class="text-[10px] font-mono font-black text-zinc-400">{t('about.header.metadata')}</span>
                    <div class="h-1 w-full bg-black"></div>
                </div>
            </div>
        </header>

        {/* Narrative Section */}
        <section class="mb-32">
            <div class="grid lg:grid-cols-2 gap-24 items-start">
                <div>
                    <h2 class="text-4xl font-black uppercase tracking-tighter mb-8 border-b-8 border-black pb-4 inline-block italic">{t('about.genesis.title')}</h2>
                    <div class="space-y-6 text-zinc-500 font-bold uppercase tracking-widest text-sm leading-relaxed">
                        <p>{t('about.genesis.p1')}</p>
                        <p>{t('about.genesis.p2')}</p>
                    </div>
                </div>
                <div class="bg-zinc-100 p-12 rounded-[3rem] relative overflow-hidden group">
                    <div class="absolute top-0 right-0 p-8 text-8xl font-black text-white group-hover:text-zinc-200 transition-colors">"</div>
                    <p class="text-2xl font-urban font-black uppercase leading-tight relative z-10">
                        {t('about.mission.quote')}
                    </p>
                    <div class="mt-8 flex gap-4 items-center">
                        <div class="w-12 h-[2px] bg-black"></div>
                        <span class="text-[10px] font-mono font-black uppercase italic">{t('about.mission.label')}</span>
                    </div>
                </div>
            </div>
        </section>

        {/* Values Modular Grid */}
        <section class="mb-32">
            <h2 class="text-3xl font-black uppercase tracking-tighter mb-16 text-center italic underline decoration-brand-red decoration-4 underline-offset-8">{t('about.values.title')}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-1">
                <div class="p-10 bg-white border-2 border-black aspect-square flex flex-col justify-between hover:bg-black hover:text-white transition-all group">
                    <span class="text-xs font-mono font-black text-zinc-300 group-hover:text-zinc-700 leading-none">{t('about.values.v1.tag')}</span>
                    <div>
                        <h4 class="text-xl font-black uppercase mb-2">{t('about.values.v1.title')}</h4>
                        <p class="text-[10px] font-bold uppercase tracking-widest opacity-60">{t('about.values.v1.desc')}</p>
                    </div>
                </div>
                <div class="p-10 bg-black text-white border-2 border-black aspect-square flex flex-col justify-between hover:bg-white hover:text-black transition-all group">
                    <span class="text-xs font-mono font-black text-zinc-700 group-hover:text-zinc-300 leading-none">{t('about.values.v2.tag')}</span>
                    <div>
                        <h4 class="text-xl font-black uppercase mb-2 italic">{t('about.values.v2.title')}</h4>
                        <p class="text-[10px] font-bold uppercase tracking-widest opacity-60 group-hover:opacity-60">{t('about.values.v2.desc')}</p>
                    </div>
                </div>
                <div class="p-10 bg-white border-2 border-black aspect-square flex flex-col justify-between hover:bg-black hover:text-white transition-all group">
                    <span class="text-xs font-mono font-black text-zinc-300 group-hover:text-zinc-700 leading-none">{t('about.values.v3.tag')}</span>
                    <div>
                        <h4 class="text-xl font-black uppercase mb-2">{t('about.values.v3.title')}</h4>
                        <p class="text-[10px] font-bold uppercase tracking-widest opacity-60">{t('about.values.v3.desc')}</p>
                    </div>
                </div>
                <div class="p-10 bg-[#202020] text-white border-2 border-black aspect-square flex flex-col justify-between hover:bg-black transition-all group">
                    <span class="text-xs font-mono font-black text-zinc-600 leading-none">{t('about.values.v4.tag')}</span>
                    <div>
                        <h4 class="text-xl font-black uppercase mb-2">{t('about.values.v4.title')}</h4>
                        <p class="text-[10px] font-bold uppercase tracking-widest opacity-60">{t('about.values.v4.desc')}</p>
                    </div>
                </div>
            </div>
        </section>

        {/* Call to Action */}
        <section class="text-center py-24 border-y-2 border-black mb-32">
            <h2 class="text-5xl md:text-7xl font-urban font-black uppercase tracking-tighter mb-12">{t('about.cta.title')}</h2>
            <div class="flex flex-col md:flex-row gap-6 justify-center">
                <a href="/category/all" class="px-12 py-5 bg-black text-white font-black uppercase tracking-widest text-sm hover:bg-zinc-800 transition-colors">{t('about.cta.explore')}</a>
                <a href="/contact" class="px-12 py-5 border-4 border-black font-black uppercase tracking-widest text-sm hover:bg-black hover:text-white transition-all">{t('about.cta.support')}</a>
            </div>
        </section>
    </div>
  </div>
</PublicLayout>

