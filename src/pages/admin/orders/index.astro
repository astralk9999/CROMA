---
export const prerender = false;
import AdminLayout from '@layouts/AdminLayout.astro';
import ConfirmationModal from '@components/islands/ConfirmationModal';
import { supabaseAdmin } from '@lib/supabase-admin';

const statusFilter = Astro.url.searchParams.get('status') || '';
const searchQuery = Astro.url.searchParams.get('search') || '';
const sortBy = Astro.url.searchParams.get('sort') || 'date_desc';
const startDate = Astro.url.searchParams.get('startDate') || '';
const endDate = Astro.url.searchParams.get('endDate') || '';

// 1. Fetch Total Absolute Count for Diagnostic
const { count: rawOrdersCount } = await supabaseAdmin
    .from('orders')
    .select('*', { count: 'exact', head: true });

// 2. Build Base Query
let query = supabaseAdmin
  .from('orders')
  .select(`
    *,
    order_items (
      *,
      product:products (name, images)
    )
  `);

// 3. Apply Server-side Filters
if (statusFilter) query = query.eq('status', statusFilter);
if (startDate) query = query.gte('created_at', `${startDate}T00:00:00`);
if (endDate) query = query.lte('created_at', `${endDate}T23:59:59`);

if (searchQuery) {
    // Note: Cannot use ilike on UUID fields directly in Supabase
    // Search only in shipping_address name (JSONB text extraction)
    query = query.ilike('shipping_address->>name', `%${searchQuery}%`);
}

// 4. Apply Sorting
if (sortBy === 'date_asc') query = query.order('created_at', { ascending: true });
else if (sortBy === 'date_desc') query = query.order('created_at', { ascending: false });
else if (sortBy === 'price_asc') query = query.order('total_amount', { ascending: true });
else if (sortBy === 'price_desc') query = query.order('total_amount', { ascending: false });
else query = query.order('created_at', { ascending: false });

// 5. Execute Query
const { data: rawFilteredOrders, error: fetchError } = await query;

// Guard against null - ensure we always have an array
const filteredOrders = rawFilteredOrders ?? [];

const statuses = ['pending', 'processing', 'shipped', 'delivered', 'cancelled'];
const statusLabels: Record<string, string> = {
  pending: 'Pendiente',
  processing: 'Procesando',
  shipped: 'Enviado',
  delivered: 'Entregado',
  cancelled: 'Cancelado'
};
---

<AdminLayout title="Bitácora de Operaciones" activeSection="orders">
  <!-- Status Control Bar (Sticky) -->
  <div class="mb-12 sticky top-0 z-[100] px-0 pt-4 pb-12 bg-zinc-50/80 backdrop-blur-xl transition-all duration-300">
    <div class="bg-zinc-800 rounded-2xl p-1 shadow-[0_20px_50px_rgba(0,0,0,0.5)] relative border border-white/5">
        <div class="absolute -top-10 left-0 text-[8px] font-black text-zinc-400 uppercase tracking-widest bg-zinc-50 px-3 py-1 rounded-t-lg border border-b-0 border-zinc-200">
          Diagnóstico: {rawOrdersCount} pedidos en DB | Filtro: {filteredOrders.length}
        </div>
        <!-- Accent Glow (Moved to clipped container) -->
        <div class="absolute inset-0 rounded-2xl overflow-hidden pointer-events-none">
            <div class="absolute -top-24 -right-24 w-96 h-96 bg-white/5 blur-[120px] rounded-full"></div>
        </div>
        
        <div class="relative z-10 flex flex-col xl:flex-row flex-wrap gap-4 items-center p-2 px-4 lg:px-6">
            <!-- Search Group -->
            <div class="relative flex-1 group/search w-full">
                <!-- Audit Status Gauge -->
                <div class="absolute -top-3 left-8 px-3 py-1 bg-zinc-800 border border-white/10 rounded-sm z-20 opacity-0 group-focus-within/search:opacity-100 transition-all duration-500 translate-y-2 group-focus-within/search:translate-y-0 flex items-center gap-3 shadow-[0_10px_30px_rgba(0,0,0,0.8)]">
                    <div class="flex gap-0.5">
                        <div class="w-1 h-1 bg-white rounded-full animate-pulse"></div>
                        <div class="w-1 h-1 bg-white/40 rounded-full animate-pulse [animation-delay:200ms]"></div>
                        <div class="w-1 h-1 bg-white/10 rounded-full animate-pulse [animation-delay:400ms]"></div>
                    </div>
                    <span class="text-[7px] font-black text-white/90 uppercase tracking-[0.4em]">Audit_Protocol.Active</span>
                </div>

                <form method="get" id="filter-form" class="relative">
                    <input type="hidden" name="status" value={statusFilter} />
                    <input type="hidden" name="sort" value={sortBy} />
                    
                    <input
                        type="text"
                        name="search"
                        id="main-search"
                        placeholder="IDENTIFICAR ORDEN POR ID O CLIENTE..."
                        value={searchQuery}
                        class="w-full bg-white/5 border-2 border-white/10 rounded-xl px-14 py-6 text-white text-[10px] font-black uppercase tracking-[0.2em] focus:outline-none focus:border-white focus:bg-zinc-700/50 focus:ring-8 focus:ring-white/[0.03] focus:shadow-[0_0_50px_rgba(255,255,255,0.08)] focus:tracking-[0.3em] transition-all duration-500 placeholder:text-white/10 placeholder:font-bold selection:bg-white selection:text-black"
                    />
                    <svg class="absolute left-6 top-1/2 -translate-y-1/2 w-5 h-5 text-white/20 group-focus-within/search:text-white group-focus-within/search:scale-110 group-hover:text-white/40 transition-all duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </form>
            </div>

                <!-- Date Filter -->
                <div class="relative group/dropdown">
                    <button type="button" id="ord-date-btn" class={`h-14 px-6 rounded-xl flex items-center justify-between gap-3 text-[9px] font-black uppercase tracking-widest transition-all border-2 bg-white/0 hover:bg-white/5 border-white/10 !text-white hover:border-white/30 ${startDate || endDate ? 'bg-white !text-black border-white' : ''}`}>
                        <svg class="w-3.5 h-3.5 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        {startDate ? `DESDE: ${startDate}` : endDate ? `HASTA: ${endDate}` : 'FECHA'}
                        <svg class="w-3 h-3 opacity-20 transition-transform arrow" id="ord-date-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div id="ord-date-menu" class="absolute top-full right-0 w-64 mt-2 bg-zinc-800 border border-white/10 rounded-2xl overflow-hidden hidden z-[200] shadow-2xl">
                        <div class="p-4 space-y-4">
                            <div class="space-y-1">
                                <a href={`?status=${statusFilter}&search=${searchQuery}&sort=${sortBy}`} class="block px-4 py-2 rounded-lg text-[8px] font-black uppercase tracking-widest text-zinc-400 hover:bg-white/5 hover:text-white transition-all">CUALQUIER FECHA</a>
                                <a href={`?status=${statusFilter}&search=${searchQuery}&sort=${sortBy}&startDate=${new Date().toISOString().split('T')[0]}`} class="block px-4 py-2 rounded-lg text-[8px] font-black uppercase tracking-widest text-zinc-400 hover:bg-white/5 hover:text-white transition-all">HOY</a>
                            </div>
                            <div class="h-px bg-white/5"></div>
                            <form method="get" class="space-y-3">
                                <input type="hidden" name="status" value={statusFilter} />
                                <input type="hidden" name="search" value={searchQuery} />
                                <input type="hidden" name="sort" value={sortBy} />
                                <div class="grid grid-cols-1 gap-2">
                                    <div class="relative">
                                        <span class="absolute -top-2 left-2 px-1 bg-zinc-800 text-[6px] font-black text-white/40 uppercase tracking-widest">Desde</span>
                                        <input type="date" name="startDate" value={startDate} class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-[9px] font-black uppercase [color-scheme:dark]" />
                                    </div>
                                    <div class="relative">
                                        <span class="absolute -top-2 left-2 px-1 bg-zinc-800 text-[6px] font-black text-white/40 uppercase tracking-widest">Hasta</span>
                                        <input type="date" name="endDate" value={endDate} class="w-full bg-white/5 border border-white/10 rounded-lg px-3 py-2 text-white text-[9px] font-black uppercase [color-scheme:dark]" />
                                    </div>
                                </div>
                                <button type="submit" class="w-full py-3 bg-white text-black text-[8px] font-black uppercase tracking-widest rounded-lg hover:bg-zinc-100 transition-all">APLICAR RANGO</button>
                            </form>
                        </div>
                    </div>
                </div>

            <!-- Vertical Divider -->
            <div class="hidden lg:block w-px h-10 bg-white/10"></div>

            <!-- Dropdowns Group -->
            <div class="grid grid-cols-2 gap-1 w-full lg:w-auto">
                <!-- Status Filter -->
                <div class="relative group/dropdown" id="status-filter-container">
                    <button type="button" id="ord-status-btn" 
                        class={`w-full h-14 px-6 rounded-xl flex items-center justify-between gap-3 text-[9px] font-black uppercase tracking-widest transition-all border-2 
                            ${statusFilter 
                                ? 'bg-white text-black border-white shadow-[0_0_20px_rgba(255,255,255,0.2)]' 
                                : 'bg-white/0 hover:bg-white/5 border-white/10 !text-white hover:border-white/30'}`}>
                        <span class="flex items-center gap-2 truncate">
                            <svg class={`w-3.5 h-3.5 ${statusFilter ? 'text-black/40' : 'text-white/40'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            {statusFilter ? (statusLabels[statusFilter]?.toUpperCase() || 'ESTADO') : 'ESTADO'}
                        </span>
                        <svg class={`w-3 h-3 transition-transform ${statusFilter ? 'text-black/40' : 'text-white/20'}`} id="ord-status-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div id="ord-status-menu" class="absolute top-full left-0 right-0 lg:w-64 mt-2 bg-zinc-800 border border-white/10 rounded-2xl overflow-hidden hidden z-[200] shadow-2xl backdrop-blur-xl">
                        <div class="p-2 space-y-1">
                            <a href={`?search=${searchQuery}&sort=${sortBy}&startDate=${startDate}&endDate=${endDate}`} class="block px-4 py-3 rounded-xl text-[8px] font-black uppercase tracking-widest text-zinc-400 hover:bg-white/5 hover:text-white transition-all">TODOS</a>
                            {statuses.map(status => (
                                <a href={`?status=${status}&search=${searchQuery}&sort=${sortBy}&startDate=${startDate}&endDate=${endDate}`} class="block px-4 py-3 rounded-xl text-[8px] font-black uppercase tracking-widest text-zinc-400 hover:bg-white/5 hover:text-white transition-all">{(statusLabels[status]?.toUpperCase() || status)}</a>
                            ))}
                        </div>
                    </div>
                </div>

                <!-- Sort Filter -->
                <div class="relative group/dropdown" id="sort-filter-container">
                    <button type="button" id="ord-sort-btn" 
                        class={`w-full h-14 px-6 rounded-2xl flex items-center justify-between gap-3 text-[9px] font-black uppercase tracking-widest transition-all border-2 
                            ${sortBy && sortBy !== 'date_desc'
                                ? 'bg-white text-black border-white shadow-[0_0_20px_rgba(255,255,255,0.2)]' 
                                : 'bg-white/0 hover:bg-white/5 border-white/10 !text-white hover:border-white/30'}`}>
                        <span class="flex items-center gap-2 truncate">
                            <svg class={`w-3.5 h-3.5 ${sortBy && sortBy !== 'date_desc' ? 'text-black/40' : 'text-white/40'}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"/></svg>
                            {sortBy === 'date_desc' ? 'FECHA ↓' : 
                             sortBy === 'date_asc' ? 'FECHA ↑' : 
                             sortBy === 'price_desc' ? 'TOTAL ↓' : 
                             sortBy === 'price_asc' ? 'TOTAL ↑' : 'ORDENAR'}
                        </span>
                        <svg class={`w-3 h-3 transition-transform ${sortBy && sortBy !== 'date_desc' ? 'text-black/40' : 'text-white/20'}`} id="ord-sort-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
                    </button>
                    <div id="ord-sort-menu" class="absolute top-full right-0 lg:w-64 mt-2 bg-zinc-800 border border-white/10 rounded-3xl overflow-hidden hidden z-[200] shadow-2xl backdrop-blur-xl">
                        <div class="p-2 space-y-1">
                            <a href={`?status=${statusFilter}&search=${searchQuery}&sort=date_desc&startDate=${startDate}&endDate=${endDate}`} class={`block px-5 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all ${sortBy === 'date_desc' ? 'bg-white text-black' : 'text-zinc-400 hover:bg-white/5 hover:text-white'}`}>
                                <span class="flex items-center justify-between gap-4">FECHA: Recientes <span class="opacity-40">↓</span></span>
                            </a>
                            <a href={`?status=${statusFilter}&search=${searchQuery}&sort=date_asc&startDate=${startDate}&endDate=${endDate}`} class={`block px-5 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all ${sortBy === 'date_asc' ? 'bg-white text-black' : 'text-zinc-400 hover:bg-white/5 hover:text-white'}`}>
                                <span class="flex items-center justify-between gap-4">FECHA: Antiguos <span class="opacity-40">↑</span></span>
                            </a>
                            <div class="h-px bg-white/5 my-1 mx-2"></div>
                            <a href={`?status=${statusFilter}&search=${searchQuery}&sort=price_desc&startDate=${startDate}&endDate=${endDate}`} class={`block px-5 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all ${sortBy === 'price_desc' ? 'bg-white text-black' : 'text-zinc-400 hover:bg-white/5 hover:text-white'}`}>
                                <span class="flex items-center justify-between gap-4">TOTAL: Mayor <span class="opacity-40">↓</span></span>
                            </a>
                            <a href={`?status=${statusFilter}&search=${searchQuery}&sort=price_asc&startDate=${startDate}&endDate=${endDate}`} class={`block px-5 py-3 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all ${sortBy === 'price_asc' ? 'bg-white text-black' : 'text-zinc-400 hover:bg-white/5 hover:text-white'}`}>
                                <span class="flex items-center justify-between gap-4">TOTAL: Menor <span class="opacity-40">↑</span></span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </div>

  <!-- Order Insights -->
  <div class="px-8 mt-12 mb-8 grid grid-cols-2 lg:grid-cols-4 gap-8">
    <div class="bg-white p-6 rounded-3xl border border-black/5 shadow-sm">
        <p class="text-[8px] font-black text-zinc-400 uppercase tracking-[0.2em] mb-2">Total Operaciones</p>
        <p class="text-2xl font-black text-black">{filteredOrders.length}</p>
    </div>
    <div class="bg-white p-6 rounded-3xl border border-black/5 shadow-sm">
        <p class="text-[8px] font-black text-zinc-400 uppercase tracking-[0.2em] mb-2">Facturación</p>
        <p class="text-2xl font-black text-black">{filteredOrders.reduce((sum, o) => sum + Number(o.total_amount), 0).toLocaleString()}€</p>
    </div>
    <div class="bg-white p-6 rounded-3xl border border-black/5 shadow-sm">
        <p class="text-[8px] font-black text-zinc-400 uppercase tracking-[0.2em] mb-2">Ticket Promedio</p>
        <p class="text-2xl font-black text-black">
            {filteredOrders.length > 0 
                ? (filteredOrders.reduce((sum, o) => sum + Number(o.total_amount), 0) / filteredOrders.length).toFixed(2) 
                : '0.00'}€
        </p>
    </div>
    <div class="bg-white p-6 rounded-3xl border border-black/5 shadow-sm border-l-red-500 border-l-4">
        <p class="text-[8px] font-black text-red-500 uppercase tracking-[0.2em] mb-2">Pendientes</p>
        <p class="text-2xl font-black text-black">{filteredOrders.filter(o => o.status === 'pending').length}</p>
    </div>
  </div>

  <!-- Results Info -->
  <div class="px-4 mb-6 flex items-center justify-between">
    <p class="text-[10px] font-black text-zinc-400 uppercase tracking-[0.3em]">
        Operaciones: <span class="text-black">{filteredOrders.length}</span> registros detectados
    </p>
    {searchQuery && (
        <div class="flex items-center gap-2 px-4 py-2 bg-zinc-800 text-white rounded-full text-[9px] font-black uppercase tracking-widest animate-fade-in-up">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            FILTRADO: {(searchQuery || '').toUpperCase()}
        </div>
    )}
  </div>

  <!-- Orders List: Industrial Table -->
  <div class="bg-white rounded-[3rem] border border-zinc-200/60 shadow-xl overflow-visible mb-20 animate-fade-in relative z-0">
    <div class="overflow-x-auto min-h-[400px] pb-40">
      <table class="w-full text-left border-collapse">
        <thead class="bg-zinc-50 border-b-2 border-zinc-100 sticky top-0 z-10">
          <tr>
            <th class="px-8 py-4 text-[10px] font-black text-black uppercase tracking-[0.2em]">ID Protocolo</th>
            <th class="px-8 py-4 text-[10px] font-black text-zinc-400 uppercase tracking-[0.2em]">Cliente / Destino</th>
            <th class="px-8 py-4 text-[10px] font-black text-zinc-400 uppercase tracking-[0.2em]">Carga / Items</th>
            <th class="px-8 py-4 text-[10px] font-black text-zinc-400 uppercase tracking-[0.2em]">Estado Actual</th>
            <th class="px-8 py-4 text-[10px] font-black text-zinc-400 uppercase tracking-[0.2em]">Balance</th>
            <th class="px-8 py-4 text-[10px] font-black text-zinc-400 uppercase tracking-[0.2em] text-right">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
            {fetchError && (
                <tr>
                    <td colspan="6" class="p-8 text-center text-red-500 font-bold uppercase tracking-widest text-xs">
                        Error de sincronización con el núcleo: {fetchError.message}
                    </td>
                </tr>
            )}

            {filteredOrders && filteredOrders.length > 0 ? (
                filteredOrders.map(order => (
                    <tr class="group hover:bg-zinc-50/80 transition-all duration-300">
                        <td class="px-8 py-5 align-top">
                            <div class="flex items-center gap-3">
                                <div class={`w-2 h-10 rounded-full ${
                                    order.status === 'pending' ? 'bg-red-500' : 
                                    order.status === 'processing' ? 'bg-amber-500' : 
                                    order.status === 'shipped' ? 'bg-blue-500' : 
                                    order.status === 'delivered' ? 'bg-emerald-500' : 
                                    'bg-zinc-300'
                                }`}></div>
                                <div>
                                    <span class="block text-xs font-black text-black uppercase tracking-widest font-mono">#{order.id.slice(0, 8)}</span>
                                    <span class="text-[9px] font-bold text-zinc-400 uppercase tracking-widest">
                                        {new Date(order.created_at).toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: '2-digit' })}
                                    </span>
                                </div>
                            </div>
                        </td>
                        <td class="px-8 py-5 align-top">
                             {order.shipping_address && typeof order.shipping_address === 'object' ? (
                                <div class="max-w-[200px]">
                                    <p class="text-[10px] font-black text-black uppercase truncate">{order.shipping_address.name}</p>
                                    <p class="text-[9px] font-bold text-zinc-500 uppercase truncate mt-0.5">{order.shipping_address.city}, {order.shipping_address.country}</p>
                                    <p class="text-[8px] font-bold text-zinc-300 uppercase truncate mt-0.5">{order.shipping_address.email}</p>
                                </div>
                             ) : (
                                <span class="text-xs text-zinc-300 uppercase">Datos no disponibles</span>
                             )}
                        </td>
                        <td class="px-8 py-5 align-top">
                            <div class="flex items-center gap-2 mb-2">
                                <span class="px-2 py-0.5 bg-zinc-100 rounded text-[9px] font-black uppercase tracking-widest text-zinc-500">
                                    {order.order_items?.length || 0} ITEMS
                                </span>
                            </div>
                            <div class="flex -space-x-2 overflow-hidden py-1">
                                {order.order_items?.slice(0, 4).map((item: any) => (
                                    <div class="w-8 h-8 rounded-full border-2 border-white bg-zinc-100 overflow-hidden relative" title={`${item.product_name} (T: ${item.size})`}>
                                        {item.product?.images?.[0] ? (
                                            <img src={item.product.images[0]} class="w-full h-full object-cover" />
                                        ) : (
                                            <div class="w-full h-full flex items-center justify-center text-[8px] font-bold text-zinc-300">No img</div>
                                        )}
                                    </div>
                                ))}
                                {(order.order_items?.length || 0) > 4 && (
                                    <div class="w-8 h-8 rounded-full border-2 border-white bg-zinc-800 text-white flex items-center justify-center text-[9px] font-bold">
                                        +{order.order_items.length - 4}
                                    </div>
                                )}
                            </div>
                        </td>
                        <td class="px-8 py-5 align-top">
                             <div class="relative w-40" id={`status-capture-${order.id}`}>
                                <button 
                                    type="button" 
                                    class={`status-dropdown-btn w-full px-3 py-1.5 rounded-lg flex items-center justify-between text-[8px] font-black uppercase tracking-widest border transition-all
                                        ${order.status === 'pending' ? 'bg-red-50 text-red-600 border-red-100 hover:bg-red-100' : 
                                          order.status === 'processing' ? 'bg-amber-50 text-amber-600 border-amber-100 hover:bg-amber-100' : 
                                          order.status === 'shipped' ? 'bg-blue-50 text-blue-600 border-blue-100 hover:bg-blue-100' : 
                                          order.status === 'delivered' ? 'bg-emerald-50 text-emerald-600 border-emerald-100 hover:bg-emerald-100' : 
                                          'bg-zinc-50 text-zinc-500 border-zinc-200'}`}
                                    data-order-id={order.id}
                                >
                                    <span>{statusLabels[order.status]?.toUpperCase() || order.status}</span>
                                    <svg class="w-3 h-3 opacity-50 status-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                </button>

                                <div class="status-dropdown-menu absolute top-full left-0 right-0 mt-1 bg-white border border-zinc-100 rounded-lg shadow-xl hidden z-50 overflow-hidden">
                                    {statuses.map(status => (
                                        <button
                                            class={`status-option-btn w-full text-left px-4 py-2 text-[8px] font-bold uppercase tracking-widest hover:bg-zinc-50 transition-colors
                                                ${order.status === status ? 'bg-black text-white hover:bg-black' : 'text-zinc-500'}`}
                                            data-order-id={order.id}
                                            data-status={status}
                                            data-label={statusLabels[status]?.toUpperCase() || status}
                                        >
                                            {statusLabels[status]?.toUpperCase() || status}
                                        </button>
                                    ))}
                                </div>
                             </div>
                        </td>
                        <td class="px-8 py-5 align-top">
                            <span class="block text-sm font-black text-black tracking-tight">{Number(order.total_amount).toFixed(2)}€</span>
                             <span class="text-[8px] font-bold text-zinc-400 uppercase tracking-widest">
                                {order.shipping_address?.shipping_method === 'express' ? 'EXPRESS 24H' : 'STANDARD'}
                             </span>
                        </td>
                        <td class="px-8 py-5 align-top text-right">
                            <div class="flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                <a href={`/admin/orders/${order.id}`} class="p-2 text-zinc-400 hover:text-black hover:bg-zinc-100 rounded-lg transition-all" title="Ver Detalles">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                </a>
                                <button
                                    type="button"
                                    class="delete-order-btn p-2 text-zinc-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-all"
                                    data-order-id={order.id}
                                    title="Eliminar Pedido"
                                >
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                </button>
                            </div>
                        </td>
                    </tr>
                ))
            ) : (
                <tr>
                    <td colspan="6" class="p-20 text-center">
                         <div class="flex flex-col items-center gap-4 opacity-50">
                            <svg class="w-12 h-12 text-zinc-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                            <p class="text-[10px] font-black text-zinc-400 uppercase tracking-widest">Sin operaciones registradas con estos filtros</p>
                        </div>
                    </td>
                </tr>
            )}
        </tbody>
      </table>
    </div>
  </div>

  <script>
    import { supabase } from '../../../lib/supabase';

    let isInitialized = false;

    // Helper for custom confirmation
    function customConfirm(title: string, message: string, variant: 'danger' | 'warning' | 'info' = 'info'): Promise<boolean> {
        return new Promise((resolve) => {
            const event = new CustomEvent('open-confirm-modal', {
                detail: {
                    title,
                    message,
                    variant,
                    confirmText: 'CONFIRMAR',
                    cancelText: 'CANCELAR',
                    onConfirm: () => resolve(true),
                    onCancel: () => resolve(false)
                }
            });
            window.dispatchEvent(event);
        });
    }

    const SCROLL_KEY = 'admin_orders_scroll_pos';

    function initPage() {
        console.log('[ADMIN] Iniciando protocolo de pedidos...');
        
        if (isInitialized) {
            console.log('[ADMIN] Pedidos ya inicializado, saltando...');
            return;
        }

        // Restore scroll
        const savedScroll = sessionStorage.getItem(SCROLL_KEY);
        if (savedScroll) {
            window.scrollTo(0, parseInt(savedScroll));
            sessionStorage.removeItem(SCROLL_KEY);
        }

        // --- GLOBAL EVENT DELEGATION ---
        document.addEventListener('click', async (e) => {
            const target = e.target as HTMLElement;
            
            // 4. DELETE ORDER ACTION
            const deleteOrderBtn = target.closest('.delete-order-btn') as HTMLButtonElement;
            if (deleteOrderBtn) {
                console.log('[ADMIN] Click en eliminar pedido detectado');
                e.preventDefault();
                e.stopPropagation();
                handleDeleteOrder(deleteOrderBtn);
                return;
            }

            // 1. TOP-LEVEL FILTERS (Status, Date, Sort)
            const filterBtn = target.closest('#ord-status-btn, #ord-sort-btn, #ord-date-btn');
            if (filterBtn) {
                e.preventDefault();
                e.stopPropagation();
                const idPrefix = filterBtn.id.replace('ord-', '').replace('-btn', '');
                const menuId = `ord-${idPrefix}-menu`;
                const arrowId = `ord-${idPrefix}-arrow`;
                
                const menu = document.getElementById(menuId);
                const arrow = document.getElementById(arrowId);
                
                document.querySelectorAll('[id^="ord-"][id$="-menu"]').forEach(m => {
                    if (m !== menu) m.classList.add('hidden');
                });
                document.querySelectorAll('[id^="ord-"][id$="-arrow"]').forEach(a => {
                    if (a !== arrow) a.classList.remove('rotate-180');
                });

                menu?.classList.toggle('hidden');
                arrow?.classList.toggle('rotate-180');
                return;
            }

            // 2. INDIVIDUAL ORDER STATUS TOGGLE
            const statusToggleBtn = target.closest('.status-dropdown-btn');
            if (statusToggleBtn) {
                e.preventDefault();
                e.stopPropagation();
                const container = statusToggleBtn.closest('.relative');
                const menu = container?.querySelector('.status-dropdown-menu');
                const arrow = container?.querySelector('.status-arrow');

                document.querySelectorAll('.status-dropdown-menu, [id^="ord-"][id$="-menu"]').forEach(m => {
                    if (m !== menu) {
                        m.classList.add('hidden');
                        const wrapper = m.closest('.relative');
                        if (wrapper && wrapper.classList.contains('w-40')) {
                            (wrapper as HTMLElement).style.zIndex = '0';
                        }
                    }
                });
                document.querySelectorAll('.status-arrow, [id^="ord-"][id$="-arrow"]').forEach(a => {
                    if (a !== arrow) a.classList.remove('rotate-180');
                });

                if (menu?.classList.contains('hidden')) {
                    menu.classList.remove('hidden');
                    if (container) (container as HTMLElement).style.zIndex = '50';
                    arrow?.classList.add('rotate-180');
                } else {
                    menu?.classList.add('hidden');
                    if (container) (container as HTMLElement).style.zIndex = '0';
                    arrow?.classList.remove('rotate-180');
                }
                return;
            }

            // 3. STATUS UPDATE ACTION
            const statusOptionBtn = target.closest('.status-option-btn') as HTMLButtonElement;
            if (statusOptionBtn) {
                e.preventDefault();
                handleStatusUpdate(statusOptionBtn);
                return;
            }

            // 5. TEST CONNECTION
            const testBtn = target.closest('#test-connection-btn');
            if (testBtn) {
                const btn = testBtn as HTMLButtonElement;
                btn.textContent = 'CONECTANDO...';
                btn.disabled = true;
                try {
                    console.log('[DIAG] Probando conexión con Supabase...');
                    const start = Date.now();
                    const { error } = await supabase.from('orders').select('count', { count: 'exact', head: true });
                    const end = Date.now();
                    if (error) throw error;
                    (window as any).showIndustrialAlert(`CONEXIÓN ACTIVA (${end - start}ms)`, 'success');
                } catch (err: any) {
                    console.log('[DIAG] Fallo de conexión:', err);
                    (window as any).showIndustrialAlert('FALLO DE RED: Supabase no responde', 'error');
                } finally {
                    btn.textContent = 'Probar Red';
                    btn.disabled = false;
                }
                return;
            }

            // Global close
            document.querySelectorAll('[id^="ord-"][id$="-menu"], .status-dropdown-menu').forEach(m => {
                m.classList.add('hidden');
                const wrapper = m.closest('.relative');
                if (wrapper && wrapper.classList.contains('w-40')) {
                    (wrapper as HTMLElement).style.zIndex = '0';
                }
            });
            document.querySelectorAll('[id^="ord-"][id$="-arrow"], .status-arrow').forEach(a => a.classList.remove('rotate-180'));
        });

        async function handleDeleteOrder(button: HTMLButtonElement) {
            const orderId = button.dataset.orderId;
            
            (window as any).showIndustrialAlert('PREPARANDO PROTOCOLO...', 'info');

            try {
                console.log('[ADMIN] Abriendo confirmación para pedido:', orderId);
                const confirmed = await customConfirm(
                    'ELIMINAR PEDIDO',
                    `¿ESTÁS SEGURO DE QUE QUIERES ELIMINAR EL PEDIDO "${orderId?.slice(0, 8)?.toUpperCase() || ''}"?`,
                    'danger'
                );

                if (!confirmed) return;

                button.disabled = true;
                button.style.opacity = '0.5';
                
                console.log('[ADMIN] Ejecutando borrado de pedido vía PROXY...');
                
                const response = await fetch('/api/admin/delete-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId })
                });

                const data = await response.json();

                if (!response.ok || data.success === false) {
                    console.log('[ADMIN] Error Proxy Pedido:', data);
                    throw new Error(data.message || 'Error en el servidor de pedidos');
                }

                const orderCard = button.closest('.group') as HTMLElement;
                if (orderCard) {
                    orderCard.style.transition = 'all 0.9s cubic-bezier(0.8, 0, 0.2, 1)';
                    orderCard.style.opacity = '0';
                    orderCard.style.transform = 'scale(0.8) translateY(100px)';
                    orderCard.style.filter = 'grayscale(1) brightness(0.5) blur(15px)';
                    orderCard.style.pointerEvents = 'none';
                }

                (window as any).showIndustrialAlert('PEDIDO ELIMINADO EXITOSAMENTE', 'success');
                sessionStorage.setItem(SCROLL_KEY, window.scrollY.toString());
                setTimeout(() => window.location.href = window.location.href, 1000);

            } catch (error: any) {
                console.log('[ADMIN] Error fatal en pedido:', error);
                (window as any).showIndustrialAlert('ERROR DE PROTOCOLO: ' + (error.message || 'Error desconocido'), 'error');
                button.disabled = false;
                button.style.opacity = '1';
            }
        }

        async function handleStatusUpdate(button: HTMLButtonElement) {
            const orderId = button.dataset.orderId;
            const newStatus = (button.dataset.status || '').toUpperCase();
            const label = button.dataset.label;
            
            try {
                const confirmed = await customConfirm(
                    'RECONFIGURAR OPERACIÓN',
                    `¿CUALIFICAR ESTADO DEL PEDIDO #${orderId?.slice(0, 8)} COMO "${label}"?`,
                    'info'
                );

                if (!confirmed) return;

                button.disabled = true;
                
                const response = await fetch('/api/admin/update-order-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId, status: button.dataset.status })
                });

                const data = await response.json();

                if (!response.ok || !data.success) {
                    throw new Error(data.message || 'Error en la actualización');
                }
                
                (window as any).showIndustrialAlert('ESTADO ACTUALIZADO Y CLIENTE NOTIFICADO', 'success');
                setTimeout(() => window.location.reload(), 800);
            } catch (error: any) {
                console.log('Error updating order:', error);
                (window as any).showIndustrialAlert('BLOQUEO DE SEGURIDAD: ' + error.message, 'error');
                button.disabled = false;
            }
        }

        isInitialized = true;
    }

    // Run on every load and View Transitions navigation
    document.addEventListener('astro:page-load', initPage);
  </script>

  <style>
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-fade-in-up {
        animation: fadeInUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
  </style>

  {/* Confirmation Modal Identity */}
  <ConfirmationModal client:load />
</AdminLayout>
