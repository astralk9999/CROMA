                                        </div>
                                    </div>
                                </div>
                                <div id="specific-emails-container" class="hidden animate-in slide-in-from-top-2 fade-in duration-300">
                                    <label class="text-[9px] font-black text-zinc-400 uppercase tracking-widest flex items-center gap-2 mb-2 px-2">
                                        <span class="w-1 h-1 bg-emerald-500 rounded-full"></span> Buscar Usuarios
                                    </label>
