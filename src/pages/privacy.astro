---
import PublicLayout from '@layouts/PublicLayout.astro';
import { ui, defaultLang, useTranslations } from '@lib/i18n';

const lang = Astro.locals.lang || defaultLang;
const t = useTranslations(lang as keyof typeof ui);
---

<PublicLayout title={t('privacy.title')}>
  <div class="container-custom py-24 min-h-[60vh]">
    <div class="max-w-4xl mx-auto">
        {/* Header Section */}
        <header class="mb-20">
            <div class="flex items-center gap-4 mb-6">
                <span class="px-3 py-1 bg-[#202020] text-white text-[10px] font-mono font-black uppercase tracking-[0.3em]">{t('privacy.header.tag')}</span>
                <div class="h-[2px] flex-1 bg-black/10"></div>
            </div>
            <h1 class="text-5xl md:text-7xl font-urban font-black uppercase tracking-tighter text-black leading-[0.85] mb-6">
                {t('privacy.header.title')}
            </h1>
            <p class="text-zinc-500 font-mono text-xs uppercase tracking-widest">
                {t('privacy.header.subtitle')}
            </p>
        </header>

        {/* Content Section */}
        <div class="space-y-16">
            <section>
                <div class="flex gap-6 items-start mb-6">
                    <span class="text-2xl font-black text-zinc-200">01</span>
                    <h2 class="text-xl font-black uppercase tracking-tight pt-1">{t('privacy.s1.title')}</h2>
                </div>
                <div class="pl-12 space-y-4 text-sm font-bold uppercase tracking-wider text-zinc-500 leading-relaxed">
                    <p>{t('privacy.s1.p1')}</p>
                    <ul class="space-y-2 border-l-2 border-zinc-100 pl-6">
                        <li>{t('privacy.s1.i1')}</li>
                        <li>{t('privacy.s1.i2')}</li>
                        <li>{t('privacy.s1.i3')}</li>
                        <li>{t('privacy.s1.i4')}</li>
                    </ul>
                </div>
            </section>

            <section>
                <div class="flex gap-6 items-start mb-6">
                    <span class="text-2xl font-black text-zinc-200">02</span>
                    <h2 class="text-xl font-black uppercase tracking-tight pt-1">{t('privacy.s2.title')}</h2>
                </div>
                <div class="pl-12 space-y-4 text-sm font-bold uppercase tracking-wider text-zinc-500 leading-relaxed">
                    <p>{t('privacy.s2.p1')}</p>
                    <ul class="space-y-2 border-l-2 border-zinc-100 pl-6">
                        <li>{t('privacy.s2.i1')}</li>
                        <li>{t('privacy.s2.i2')}</li>
                        <li>{t('privacy.s2.i3')}</li>
                        <li>{t('privacy.s2.i4')}</li>
                    </ul>
                </div>
            </section>

            <section>
                <div class="flex gap-6 items-start mb-6">
                    <span class="text-2xl font-black text-zinc-200">03</span>
                    <h2 class="text-xl font-black uppercase tracking-tight pt-1">{t('privacy.s3.title')}</h2>
                </div>
                <div class="pl-12 text-sm font-bold uppercase tracking-wider text-zinc-500 leading-relaxed">
                    <p>{t('privacy.s3.p1')}</p>
                </div>
            </section>

            <section>
                <div class="p-10 bg-zinc-50 border-2 border-black rounded-[2rem]">
                    <div class="flex gap-6 items-start mb-6">
                        <span class="text-2xl font-black text-black">04</span>
                        <h2 class="text-xl font-black uppercase tracking-tight pt-1 italic underline">{t('privacy.s4.title')}</h2>
                    </div>
                    <div class="pl-12 space-y-4 text-[11px] font-black uppercase tracking-[0.2em] text-zinc-600 leading-loose">
                        <p>{t('privacy.s4.p1')}</p>
                        <p>{t('privacy.s4.p2').split('{email}')[0]}<span class="text-black underline">PRIVACY@CROMA.ES</span>{t('privacy.s4.p2').split('{email}')[1]}</p>
                    </div>
                </div>
            </section>
        </div>

        {/* Action Link */}
        <div class="mt-24 pt-12 border-t border-zinc-100 flex justify-between items-center">
            <span class="text-[10px] font-mono font-black text-zinc-300">{t('privacy.footer.end')}</span>
            <a href="/contact" class="text-[10px] font-black uppercase tracking-widest hover:underline decoration-2 underline-offset-4">{t('privacy.footer.support')}</a>
        </div>
    </div>
  </div>
</PublicLayout>
